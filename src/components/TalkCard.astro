---
import { formatDate } from '../lib/format';

interface Props {
  slug: string;
  title: string;
  date: Date;
  description: string;
  event?: string;
  tags?: string[];
  cover?: string;
}

const { slug, title, date, description, event, tags = [], cover } = Astro.props;
const url = `/talks/${slug}/`;
const dateStr = formatDate(date);
---

<article class="talk-card">
  <div class="card-body">
    <div class="meta">
      <time datetime={date.toISOString()}>{dateStr}</time>
      {event && <span class="event">{event}</span>}
      {tags.map((tag) => <span class="tag">#{tag}</span>)}
    </div>
    <h2 class="title">
      <a href={url}>{title}</a>
    </h2>
    <p class="desc">{description}</p>
  </div>
  {cover && (
    <a class="thumb" href={url} aria-hidden="true" tabindex="-1">
      <img src={cover} alt="" loading="lazy" />
    </a>
  )}
</article>

<style>
  .talk-card {
    display: flex;
    align-items: flex-start;
    gap: clamp(1.25rem, 3vw, 2rem);
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .card-body {
    flex: 1;
    min-width: 0;
  }
  .thumb {
    flex-shrink: 0;
    display: block;
    width: clamp(132px, 24vw, 200px);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .thumb img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  @media (max-width: 680px) {
    .thumb {
      width: 112px;
    }
  }
  @media (max-width: 560px) {
    .talk-card {
      flex-direction: column;
      align-items: stretch;
      gap: 0.85rem;
    }
    .thumb {
      order: -1;
      width: 100%;
    }
    .thumb img {
      aspect-ratio: 16 / 9;
    }
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--fg-subtle);
    margin-bottom: 0.5rem;
  }
  .event {
    color: var(--fg-muted);
  }
  .tag {
    color: var(--fg-muted);
  }
  .title {
    margin: 0 0 0.4rem;
    font-size: 1.3rem;
  }
  .title a:hover {
    text-decoration: none;
    color: var(--accent-hover);
  }
  .desc {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.97rem;
    line-height: 1.65;
  }
</style>
