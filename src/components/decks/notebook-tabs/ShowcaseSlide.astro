---
import Md from './primitives/Md.astro';
import SlideHead from './primitives/SlideHead.astro';
import RefLinks from './primitives/RefLinks.astro';

const { slide } = Astro.props;
---

<SlideHead kicker={slide.kicker} heading={slide.heading} />
<div class="showcase-body reveal">
  <div class="showcase-code">
    {slide.skill && <span class="skill-tag">{slide.skill}</span>}
    <div class="code-block">{slide.code}</div>
  </div>
  <div class="showcase-diagram mermaid-wrap">
    <pre class="mermaid">{slide.mermaid}</pre>
  </div>
</div>
{slide.lead && (
  <Md as="p" class="lead reveal" style="margin-top:clamp(1.2rem,3.2vh,2rem)" text={slide.lead} />
)}
{slide.refs && slide.refs.length > 0 && <RefLinks refs={slide.refs} />}
