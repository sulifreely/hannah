---
import { marked } from 'marked';

const { slide } = Astro.props;
const headingHtml = marked.parseInline(slide.heading) as string;
const leadHtml = slide.lead ? (marked.parseInline(slide.lead) as string) : '';
---

<div class="head-block">
  {slide.kicker && <span class="kicker-num reveal">{slide.kicker}</span>}
  <h2 class="reveal" set:html={headingHtml} />
</div>
<div class="diagram-wrap reveal">
  <div class="diagram-row">
    {slide.steps.map((step: { label: string; variant?: 'ghost' | 'hero' }, i: number) => (
      <>
        {i > 0 && <div class="arrow-h" />}
        <div
          class={`chip ${step.variant === 'hero' ? 'chip-hero' : step.variant === 'ghost' ? 'chip-ghost' : ''}`}
          set:html={marked.parseInline(step.label) as string}
        />
      </>
    ))}
  </div>
  {slide.retry && (
    <div class="arrow-loop">
      <span class="loop-glyph">↺</span>
      <span set:html={marked.parseInline(slide.retry) as string} />
    </div>
  )}
</div>
{slide.lead && <p class="lead reveal" set:html={leadHtml} />}
{slide.bullets && (
  <ul class="bullets reveal">
    {slide.bullets.map((b: string) => <li set:html={marked.parseInline(b) as string} />)}
  </ul>
)}
{slide.refs && slide.refs.length > 0 && (
  <div class="ref-links reveal">
    <span class="ref-label">参考 Skill →</span>
    {slide.refs.map((ref: { label: string; href: string }) => (
      <a class="ref-link" href={ref.href} target="_blank" rel="noopener">
        {ref.label}<span class="ext-icon">↗</span>
      </a>
    ))}
  </div>
)}
