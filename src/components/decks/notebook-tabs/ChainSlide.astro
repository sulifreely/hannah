---
import Md from './primitives/Md.astro';
import SlideHead from './primitives/SlideHead.astro';
import Bullets from './primitives/Bullets.astro';
import RefLinks from './primitives/RefLinks.astro';

const { slide } = Astro.props;
---

<SlideHead kicker={slide.kicker} heading={slide.heading} />
<div
  class="diagram-wrap reveal"
  style={(slide.lead || slide.bullets || slide.refs) ? 'margin-bottom:clamp(1.2rem,3vh,2rem)' : undefined}
>
  <div class="diagram-row">
    {slide.steps.map((step: { label: string; variant?: 'ghost' | 'hero' }, i: number) => (
      <>
        {i > 0 && <div class="arrow-h" />}
        <Md
          as="div"
          class={`chip ${step.variant === 'hero' ? 'chip-hero' : step.variant === 'ghost' ? 'chip-ghost' : ''}`}
          text={step.label}
        />
      </>
    ))}
  </div>
  {slide.retry && (
    <div class="arrow-loop">
      <span class="loop-glyph">↺</span>
      <Md as="span" text={slide.retry} />
    </div>
  )}
</div>
{slide.lead && <Md as="p" class="lead reveal" text={slide.lead} />}
{slide.bullets && <Bullets items={slide.bullets} />}
{slide.refs && slide.refs.length > 0 && <RefLinks refs={slide.refs} />}
