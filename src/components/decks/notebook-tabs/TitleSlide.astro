---
import Md from './primitives/Md.astro';

const { slide } = Astro.props;
---

<div class="title-text">
  {slide.eyebrow && <Md as="p" class="eyebrow reveal" text={slide.eyebrow} />}
  <Md as="h1" class="reveal" style="margin-top:clamp(.6rem,1.6vh,1rem)" text={slide.title} />
  {slide.lead && (
    <Md as="p" class="lead reveal" style="margin-top:clamp(1rem,2.6vh,1.6rem)" text={slide.lead} />
  )}
  <div class="rule reveal" style="margin-top:clamp(1.2rem,3vh,2rem)" />
</div>
{slide.cover && (
  <div class="title-cover reveal">
    <div class="tape" />
    <img src={slide.cover} alt={slide.coverAlt ?? ''} />
  </div>
)}
