---
import Md from './primitives/Md.astro';
import SlideHead from './primitives/SlideHead.astro';

const { slide } = Astro.props;
---

<SlideHead kicker={slide.kicker} heading={slide.heading} />
<div class="split">
  {slide.columns.map((col: { label: string; dot?: string; items: string[] }) => (
    <div class="split-col reveal">
      <div class="col-label">
        <span class="dot" style={`background:${col.dot ?? 'var(--text-faint)'}`} />
        {col.label}
      </div>
      <ul class="bullets">
        {col.items.map((item) => <li><Md text={item} /></li>)}
      </ul>
    </div>
  ))}
</div>
