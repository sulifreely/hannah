---
import Md from './primitives/Md.astro';
import SlideHead from './primitives/SlideHead.astro';

const { slide } = Astro.props;
const cols = slide.columns ?? 3;
---

<SlideHead kicker={slide.kicker} heading={slide.heading} />
<div class="card-grid" style={`grid-template-columns:repeat(${cols},1fr)`}>
  {slide.cards.map((card: { num: string; title: string; desc: string }, i: number) => (
    <div class="feature-card reveal" style={`border-color:var(--tab-${(i % 6) + 1})`}>
      <span class="f-num">{card.num}</span>
      <Md as="span" class="f-title" text={card.title} />
      <Md as="span" class="f-desc" text={card.desc} />
    </div>
  ))}
</div>
{slide.lead && (
  <Md as="p" class="lead reveal" style="margin-top:clamp(1rem,2.6vh,1.6rem)" text={slide.lead} />
)}
