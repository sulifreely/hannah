---
import Md from './primitives/Md.astro';

const { slide } = Astro.props;
---

{slide.eyebrow && <Md as="p" class="eyebrow reveal" text={slide.eyebrow} />}
<Md
  as="blockquote"
  class="reveal"
  style={slide.eyebrow ? 'margin-top:clamp(1rem,2.6vh,1.6rem)' : undefined}
  text={slide.quote}
/>
{slide.lead && (
  <Md as="p" class="lead reveal" style="margin-top:clamp(1rem,2.6vh,1.6rem)" text={slide.lead} />
)}
{slide.heading && (
  <>
    <div class="rule reveal" style="margin:clamp(1.4rem,3.5vh,2.2rem) auto 0" />
    <Md as="h2" class="reveal" style="margin-top:clamp(1rem,2.6vh,1.6rem)" text={slide.heading} />
  </>
)}
