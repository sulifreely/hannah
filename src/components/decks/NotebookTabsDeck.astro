---
import type { CollectionEntry } from 'astro:content';
import Analytics from '@vercel/analytics/astro';
import '@fontsource/comic-neue/400.css';
import '@fontsource/comic-neue/700.css';
import '../../styles/decks/notebook-tabs.css';
import DeferredLxgw from '../DeferredLxgw.astro';
import { SLIDE_RENDERERS } from './notebook-tabs/registry';

type Props = { talk: CollectionEntry<'talks'> };

const { talk } = Astro.props;
if (talk.data.template !== 'deck') {
  throw new Error(`NotebookTabsDeck rendered for a non-deck talk: ${talk.slug}`);
}
const deck = talk.data.deck;
const slides = deck.slides;
const sections = deck.sections ?? [];

function slideClass(slide: (typeof slides)[number]) {
  return [
    'slide',
    slide.type === 'title' ? 'title-slide' : '',
    slide.type === 'quote' && slide.centered ? 'closing' : '',
  ]
    .filter(Boolean)
    .join(' ');
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{talk.data.title} · Slides</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="robots" content="noindex" />
    <DeferredLxgw />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,wght@0,400;0,700;0,900;1,500&family=Noto+Serif+SC:wght@500;700;900&family=DM+Sans:wght@400;500;700&family=DM+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;700&display=swap"
    />
  </head>
  <body class="deck-root">
    <div data-export-strip>
      <Analytics />
    </div>
    <div class="progress-bar" id="progressBar"></div>
    <nav class="nav-dots" id="navDots"></nav>
    {sections.length > 0 && (
      <div class="tabs" id="sectionTabs">
        {sections.map((sec) => (
          <div class="tab" data-tab={sec.id}>{sec.label}</div>
        ))}
      </div>
    )}
    <div class="keyboard-hint">← → · Space · Scroll</div>
    <a class="deck-back-link" data-export-strip href={`/talks/${talk.slug}/`}>← {talk.data.title}</a>

    {slides.map((slide, i) => {
      const SlideComponent = SLIDE_RENDERERS[slide.type];
      const page = i + 1;
      return (
        <section class={slideClass(slide)} data-section={slide.section}>
          <div class="page">
            <div class="binder">
              <span></span><span></span><span></span><span></span><span></span><span></span>
            </div>
            <SlideComponent slide={slide as any} />
            <span class="page-num" aria-label={`第 ${page} 页，共 ${slides.length} 页`}>
              {page}<span class="page-num-sep">/</span>{slides.length}
            </span>
          </div>
        </section>
      );
    })}

    <script>
      import { readPositionFromSearch, syncPositionToURL } from '../../lib/deck/url-state';

      class SlidePresentation {
        slides: HTMLElement[];
        currentSlide: number;
        progressBar: HTMLElement | null;
        navDotsContainer: HTMLElement | null;
        tabs: HTMLElement[];

        constructor() {
          this.slides = Array.from(document.querySelectorAll('.slide'));
          this.currentSlide = 0;
          this.progressBar = document.getElementById('progressBar');
          this.navDotsContainer = document.getElementById('navDots');
          this.tabs = Array.from(document.querySelectorAll('.tab'));

          this.setupIntersectionObserver();
          this.setupKeyboardNav();
          this.setupTouchNav();
          this.setupProgressBar();
          this.setupNavDots();
        }

        setupIntersectionObserver() {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting && entry.intersectionRatio > 0.55) {
                  entry.target.classList.add('visible');
                  const idx = this.slides.indexOf(entry.target as HTMLElement);
                  if (idx !== -1) this.updateActive(idx);
                }
              });
            },
            { threshold: [0, 0.55, 1] },
          );
          this.slides.forEach((s) => observer.observe(s));
        }

        // Every talk's slides route is controlled by the same `?scene=N&beat=0`
        // URL contract (shared with the ScenesDeck template via
        // src/lib/deck/url-state.ts) so links/deep-links are consistent
        // across both slide templates. This template has no sub-slide
        // "beat" reveal step, so beat always resolves to 0.
        readSceneFromURL() {
          return readPositionFromSearch(location.search, this.slides.length).scene;
        }

        updateActive(idx: number) {
          this.currentSlide = idx;
          this.navDotsContainer?.querySelectorAll('.nav-dot').forEach((d, i) => {
            d.classList.toggle('active', i === idx);
          });
          const section = this.slides[idx].dataset.section;
          this.tabs.forEach((t) => t.classList.toggle('active', t.dataset.tab === section));
          syncPositionToURL({ scene: idx, beat: 0 });
        }

        goTo(idx: number, behavior: ScrollBehavior = 'smooth') {
          idx = Math.max(0, Math.min(this.slides.length - 1, idx));
          if (behavior === 'auto') {
            // Force a true instant jump (used for the initial deep-link and
            // popstate) regardless of the page's CSS scroll-behavior.
            const prev = document.documentElement.style.scrollBehavior;
            document.documentElement.style.scrollBehavior = 'auto';
            this.slides[idx].scrollIntoView();
            document.documentElement.style.scrollBehavior = prev;
          } else {
            this.slides[idx].scrollIntoView({ behavior });
          }
        }

        setupKeyboardNav() {
          document.addEventListener('keydown', (e) => {
            if (['ArrowDown', 'ArrowRight', 'PageDown', ' '].includes(e.key)) {
              e.preventDefault();
              this.goTo(this.currentSlide + 1);
            } else if (['ArrowUp', 'ArrowLeft', 'PageUp'].includes(e.key)) {
              e.preventDefault();
              this.goTo(this.currentSlide - 1);
            }
          });
        }

        setupTouchNav() {
          let startY: number | null = null;
          document.addEventListener(
            'touchstart',
            (e) => {
              startY = e.touches[0].clientY;
            },
            { passive: true },
          );
          document.addEventListener(
            'touchend',
            (e) => {
              if (startY === null) return;
              const dy = startY - e.changedTouches[0].clientY;
              if (Math.abs(dy) > 50) this.goTo(this.currentSlide + (dy > 0 ? 1 : -1));
              startY = null;
            },
            { passive: true },
          );

          let wheelLock = false;
          window.addEventListener(
            'wheel',
            (e) => {
              if (wheelLock) return;
              if (Math.abs(e.deltaY) < 10) return;
              wheelLock = true;
              this.goTo(this.currentSlide + (e.deltaY > 0 ? 1 : -1));
              setTimeout(() => {
                wheelLock = false;
              }, 700);
            },
            { passive: true },
          );
        }

        setupProgressBar() {
          const update = () => {
            const scrollTop = window.scrollY;
            const max = document.documentElement.scrollHeight - window.innerHeight;
            const pct = max > 0 ? (scrollTop / max) * 100 : 0;
            if (this.progressBar) this.progressBar.style.width = pct + '%';
          };
          window.addEventListener('scroll', update, { passive: true });
          update();
        }

        setupNavDots() {
          if (!this.navDotsContainer) return;
          this.navDotsContainer.innerHTML = '';
          this.slides.forEach((_, i) => {
            const dot = document.createElement('button');
            dot.className = 'nav-dot' + (i === 0 ? ' active' : '');
            dot.setAttribute('aria-label', 'Slide ' + (i + 1));
            dot.addEventListener('click', () => this.goTo(i));
            this.navDotsContainer!.appendChild(dot);
          });
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        const presentation = new SlidePresentation();
        const initialIdx = presentation.readSceneFromURL();
        presentation.slides[initialIdx]?.classList.add('visible');
        presentation.goTo(initialIdx, 'auto');
        presentation.updateActive(initialIdx);

        window.addEventListener('popstate', () => {
          presentation.goTo(presentation.readSceneFromURL(), 'auto');
        });
      });
    </script>

    <script>
      // Same Mermaid pipeline as blog posts (see remarkMermaid in
      // astro.config.mjs + PostLayout.astro) so a diagram slide reused
      // 1:1 from a blog post renders in the exact same hand-drawn style.
      // Unlike the blog, this deck has no light/dark toggle — the slide
      // "page" is always the light paper card — so theme is fixed.
      (async function () {
        const blocks = Array.from(document.querySelectorAll<HTMLElement>('pre.mermaid'));
        if (!blocks.length) return;

        blocks.forEach((el, i) => {
          el.dataset.src = el.textContent || '';
          if (!el.id) el.id = 'deck-mermaid-' + i;
        });

        // fontSize matches --body-size's upper bound (notebook-tabs.css) so
        // node labels read at the same scale as the slide's own body text,
        // not as a separately-scaled diagram font.
        const { default: mermaid } = await import('mermaid');
        mermaid.initialize({
          startOnLoad: false,
          look: 'handDrawn',
          handDrawnSeed: 1,
          theme: 'neutral',
          securityLevel: 'strict',
          fontFamily: '"DM Sans", "Noto Sans SC", sans-serif',
          fontSize: 16,
        });

        // Mermaid renders each svg at its own "natural" size (governed by
        // fontSize above) and inlines a matching max-width. That natural
        // size is the target — moderate, consistent with body text — so
        // only ever shrink it down here, never enlarge it, and only when it
        // wouldn't otherwise fit the card: a plain CSS max-width can't win
        // this because mermaid's inline style already outranks it.
        const MAX_DIAGRAM_HEIGHT = 280;
        function fitMermaidSvg(container: HTMLElement) {
          const svg = container.querySelector('svg');
          const wrap = container.parentElement;
          if (!svg || !wrap) return;
          const box = svg.viewBox?.baseVal;
          const naturalWidth = box?.width || svg.getBBox().width;
          const naturalHeight = box?.height || svg.getBBox().height;
          const availWidth = wrap.clientWidth;
          if (!naturalWidth || !naturalHeight || !availWidth) return;
          const scale = Math.min(1, availWidth / naturalWidth, MAX_DIAGRAM_HEIGHT / naturalHeight);
          svg.style.maxWidth = 'none';
          svg.style.maxHeight = 'none';
          svg.style.width = `${naturalWidth * scale}px`;
          svg.style.height = `${naturalHeight * scale}px`;
        }

        const rendered: HTMLElement[] = [];
        for (const el of blocks) {
          try {
            await mermaid.run({ nodes: [el] });
            rendered.push(el);
          } catch (e) {
            el.dataset.processed = 'error';
            /* 单个图表语法错误时不阻断其他图表 */
          }
        }
        rendered.forEach(fitMermaidSvg);

        // Fit is computed in pixels against the wrapper's current width, so
        // narrow viewports (where the card itself shrinks) need a refit —
        // webfonts finishing their swap can also nudge that width slightly.
        document.fonts?.ready.then(() => rendered.forEach(fitMermaidSvg));
        let resizeTimer: number | undefined;
        window.addEventListener('resize', () => {
          window.clearTimeout(resizeTimer);
          resizeTimer = window.setTimeout(() => rendered.forEach(fitMermaidSvg), 150);
        });
      })();
    </script>
  </body>
</html>
