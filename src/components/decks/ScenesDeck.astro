---
import type { CollectionEntry } from 'astro:content';
import { marked } from 'marked';
import Analytics from '@vercel/analytics/astro';
import ThemeToggle from '../ThemeToggle.astro';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';
import '../../styles/global.css';
import '../../styles/decks/chrome.css';
import DeferredLxgw from '../DeferredLxgw.astro';

type Props = { talk: CollectionEntry<'talks'> };

const { talk } = Astro.props;

const scenes = talk.body
  .split(/\n[ \t]*-{3,}[ \t]*\n/)
  .map((scene) => scene.trim())
  .filter(Boolean)
  .map((scene) =>
    scene
      .split(/\n[ \t]*\+{3,}[ \t]*\n/)
      .map((beat) => marked.parse(beat.trim()) as string),
  );
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{talk.data.title} · Slides</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="robots" content="noindex" />
    <DeferredLxgw />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', stored || (prefersDark ? 'dark' : 'light'));
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="deck-body">
    <div data-export-strip>
      <Analytics />
    </div>
    <main id="deck" class="deck">
      {scenes.map((beats, si) => (
        <section class="slide" data-scene={si}>
          <div class="slide-inner">
            {beats.map((html, bi) => (
              <div class="beat" data-beat={bi} set:html={html} />
            ))}
          </div>
        </section>
      ))}
    </main>

    <div class="hud">
      <a class="hud-back" data-export-strip href={`/talks/${talk.slug}/`}>← {talk.data.title}</a>
      <div class="hud-right">
        <span class="hud-progress"><span id="cur">1</span> / {scenes.length}</span>
        <span data-export-strip>
          <ThemeToggle />
        </span>
      </div>
    </div>

    <script>
      import { clamp, readPositionFromSearch, syncPositionToURL } from '../../lib/deck/url-state';

      const deck = document.getElementById('deck')!;
      const slides = Array.from(deck.querySelectorAll('.slide'));
      const sceneCount = slides.length;
      const beatsOf = (i: number) => slides[i].querySelectorAll('.beat').length;

      let scene = 0;
      let beat = 0;

      function readURL() {
        ({ scene, beat } = readPositionFromSearch(location.search, sceneCount, beatsOf));
      }

      function render() {
        slides.forEach((sl, i) => {
          const active = i === scene;
          sl.classList.toggle('active', active);
          sl.querySelectorAll('.beat').forEach((b, bi) => {
            b.classList.toggle('revealed', active ? bi <= beat : true);
          });
        });
        const cur = document.getElementById('cur');
        if (cur) cur.textContent = String(scene + 1);
        syncPositionToURL({ scene, beat });
      }

      function next() {
        if (beat < beatsOf(scene) - 1) beat++;
        else if (scene < sceneCount - 1) { scene++; beat = 0; }
        else return;
        render();
      }

      function prev() {
        if (beat > 0) beat--;
        else if (scene > 0) { scene--; beat = Math.max(0, beatsOf(scene) - 1); }
        else return;
        render();
      }

      function go(s: number, b: number) {
        scene = clamp(s, 0, sceneCount - 1);
        beat = clamp(b, 0, Math.max(0, beatsOf(scene) - 1));
        render();
      }

      function toggleFs() {
        if (document.fullscreenElement) document.exitFullscreen();
        else document.documentElement.requestFullscreen?.();
      }

      document.addEventListener('keydown', (e) => {
        switch (e.key) {
          case 'ArrowRight':
          case 'ArrowDown':
          case ' ':
          case 'PageDown':
            e.preventDefault(); next(); break;
          case 'ArrowLeft':
          case 'ArrowUp':
          case 'PageUp':
            e.preventDefault(); prev(); break;
          case 'Home':
            e.preventDefault(); go(0, 0); break;
          case 'End':
            e.preventDefault(); go(sceneCount - 1, beatsOf(sceneCount - 1) - 1); break;
          case 'f':
          case 'F':
            toggleFs(); break;
          case 'Escape':
            if (document.fullscreenElement) document.exitFullscreen(); break;
        }
      });

      deck.addEventListener('click', (e) => {
        if ((e.target as Element | null)?.closest('a, button')) return;
        const x = e.clientX / window.innerWidth;
        if (x > 0.5) next(); else prev();
      });

      window.addEventListener('popstate', () => { readURL(); render(); });

      readURL();
      render();
    </script>
  </body>
</html>

<style>
  .deck-body {
    margin: 0;
    height: 100vh;
    overflow: hidden;
    background: var(--bg);
    color: var(--fg);
  }
  .deck {
    position: fixed;
    inset: 0;
    cursor: default;
  }
  .slide {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 6vh 8vw;
  }
  .slide.active {
    display: flex;
  }
  .slide-inner {
    width: 100%;
    max-width: 880px;
  }
  .beat {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .beat.revealed {
    opacity: 1;
    transform: none;
  }
  .slide-inner :global(h1) {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .slide-inner :global(h2) {
    font-size: clamp(1.8rem, 4.5vw, 2.6rem);
    line-height: 1.25;
    margin: 0 0 1.25rem;
  }
  .slide-inner :global(h3) {
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    font-weight: 500;
    color: var(--fg-muted);
    margin: 0 0 0.75rem;
  }
  .slide-inner :global(p),
  .slide-inner :global(li) {
    font-size: clamp(1.1rem, 2.6vw, 1.6rem);
    line-height: 1.7;
  }
  .slide-inner :global(ul),
  .slide-inner :global(ol) {
    padding-left: 1.4em;
  }
  .slide-inner :global(li) {
    margin: 0.5em 0;
  }
  .slide-inner :global(blockquote) {
    margin: 0;
    padding-left: 1rem;
    border-left: 4px solid var(--border);
    color: var(--fg-muted);
    font-size: clamp(1.3rem, 3.4vw, 2rem);
    line-height: 1.6;
  }
  .slide-inner :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .slide-inner :global(code) {
    font-family: var(--font-mono);
    background: var(--code-bg);
    padding: 0.1em 0.35em;
    border-radius: 5px;
    font-size: 0.85em;
  }
  .slide-inner :global(pre) {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.2rem;
    overflow-x: auto;
    font-size: clamp(0.9rem, 2vw, 1.25rem);
    line-height: 1.5;
  }
  .slide-inner :global(pre code) {
    background: none;
    padding: 0;
    font-size: 1em;
  }
  .slide-inner :global(img) {
    display: block;
    max-width: 100%;
    max-height: 56vh;
    margin: 0.5rem auto 0;
    border-radius: 10px;
    background: #fff;
    padding: 0.5rem;
    border: 1px solid var(--border);
  }
  .slide-inner :global(strong) {
    font-weight: 700;
  }

  .hud {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--deck-corner-inset-y) var(--deck-corner-inset-x);
    font-size: 0.85rem;
    color: var(--fg-subtle);
    z-index: var(--deck-corner-z);
    pointer-events: none;
  }
  .hud a,
  .hud button,
  .hud .hud-progress {
    pointer-events: auto;
  }
  /* Same corner-spacing + interaction convention (src/styles/decks/
     chrome.css) as NotebookTabsDeck's .deck-back-link — colors stay
     theme-adaptive here since ScenesDeck supports light/dark toggling. */
  .hud-back {
    color: var(--fg-subtle);
    max-width: 50vw;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: var(--deck-meta-transition);
  }
  .hud-back:hover {
    color: var(--fg);
    text-decoration: none;
  }
  .hud-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .hud-progress {
    font-variant-numeric: tabular-nums;
  }
</style>
