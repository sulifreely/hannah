---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/', label: '博客' },
  { href: '/talks', label: '分享' },
  { href: '/about', label: '关于' },
];

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---

<header class="site-header">
  <div class="wrap inner">
    <a href="/" class="brand">蘇里</a>
    <nav>
      {links.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { active: isActive(link.href) }]}
        >
          {link.label}
        </a>
      ))}
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
  }
  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    font-family: var(--font-serif);
    color: var(--fg);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.01em;
  }
  .brand:hover {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .nav-link {
    padding: 0.35rem 0.6rem;
    border-radius: 8px;
    font-size: 0.95rem;
    color: var(--fg-muted);
  }
  .nav-link:hover {
    color: var(--fg);
    background: var(--tag-bg);
    text-decoration: none;
  }
  .nav-link.active {
    color: var(--accent);
    font-weight: 700;
  }
</style>
