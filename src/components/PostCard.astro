---
interface Props {
  url: string;
  title: string;
  date: Date;
  description: string;
  tags?: string[];
}

const { url, title, date, description, tags = [] } = Astro.props;

const dateStr = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(date);
---

<article class="post-card">
  <div class="meta">
    <time datetime={date.toISOString()}>{dateStr}</time>
    {tags.length > 0 && (
      <span class="tags">
        {tags.map((tag) => <span class="tag">#{tag}</span>)}
      </span>
    )}
  </div>
  <h2 class="title">
    <a href={url}>{title}</a>
  </h2>
  <p class="desc">{description}</p>
</article>

<style>
  .post-card {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--fg-subtle);
    margin-bottom: 0.5rem;
  }
  .tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    color: var(--fg-muted);
  }
  .title {
    margin: 0 0 0.4rem;
    font-size: 1.3rem;
  }
  .title a:hover {
    text-decoration: none;
    color: var(--accent-hover);
  }
  .desc {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.97rem;
    line-height: 1.65;
  }
</style>
