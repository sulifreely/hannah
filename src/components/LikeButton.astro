---
import Heart from '@lucide/astro/icons/heart';
import type { ContentType } from '../lib/analytics';
import { SHOW_ENGAGEMENT_COUNTS } from '../lib/engagement';

interface Props {
  slug: string;
  title: string;
  contentType?: ContentType;
}

const { slug, title, contentType = 'blog' } = Astro.props;
// 每个内容各自记一份「本机是否已点赞」状态，纯前端展示用，不代表全站真实点赞数。
const storageKey = `liked:${contentType}:${slug}`;
---

<button
  class="like-button"
  type="button"
  aria-pressed="false"
  data-like-button
  data-slug={slug}
  data-title={title}
  data-content-type={contentType}
  data-storage-key={storageKey}
  data-show-count={SHOW_ENGAGEMENT_COUNTS ? '1' : '0'}
>
  <Heart class="like-icon" size={16} stroke-width={2} />
  <span class="like-label">喜欢这篇文章</span>
  <span class:list={['like-count', { 'is-hidden': !SHOW_ENGAGEMENT_COUNTS }]} data-like-count>···</span>
</button>

<style>
  .like-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 1rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--paper);
    color: var(--fg-muted);
    font-family: inherit;
    font-size: 0.85rem;
    line-height: 1;
    box-shadow: 2px 2px 0 var(--border);
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }
  .like-button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .like-button:active {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 var(--border);
  }
  .like-icon {
    flex-shrink: 0;
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .like-count {
    font-variant-numeric: tabular-nums;
    color: var(--fg-subtle);
  }
  .like-count.is-hidden {
    display: none;
  }
  .like-count::before {
    content: "·";
    margin-right: 0.5rem;
    color: var(--border);
  }
  .like-button.is-liked .like-count {
    color: var(--accent);
  }
  .like-button.is-liked {
    color: var(--accent);
    border-color: var(--accent);
  }
  .like-button.is-liked .like-icon {
    fill: var(--accent);
    color: var(--accent);
  }
  .like-button.is-animating .like-icon {
    animation: like-pop 0.35s ease;
  }
  @keyframes like-pop {
    0% {
      transform: scale(1);
    }
    45% {
      transform: scale(1.35);
    }
    100% {
      transform: scale(1);
    }
  }
</style>

<script>
  import { AnalyticsEvents, type ContentType } from '../lib/analytics';
  import { formatCount } from '../lib/format';

  interface LikesResponse {
    likes: Record<string, number>;
  }
  interface ToggleResponse {
    slug: string;
    contentType: string;
    likes: number;
  }

  function setState(btn: HTMLButtonElement, liked: boolean) {
    btn.classList.toggle('is-liked', liked);
    btn.setAttribute('aria-pressed', String(liked));
    const label = btn.querySelector('.like-label');
    if (label) label.textContent = liked ? '感谢喜欢' : '喜欢这篇文章';
  }

  function showsCount(btn: HTMLButtonElement): boolean {
    return btn.dataset.showCount !== '0';
  }

  function setCount(btn: HTMLButtonElement, count: number) {
    if (!showsCount(btn)) return;
    const target = btn.querySelector('.like-count');
    if (target) target.textContent = formatCount(Math.max(0, count));
  }

  function currentCount(btn: HTMLButtonElement): number {
    const target = btn.querySelector('.like-count');
    return Number(target?.textContent) || 0;
  }

  async function fetchInitialCounts(buttons: HTMLButtonElement[]) {
    const visible = buttons.filter(showsCount);
    if (!visible.length) return;

    // 按 contentType 分组批量查询，避免一个页面多个点赞按钮各发一个请求。
    const groups = new Map<string, HTMLButtonElement[]>();
    visible.forEach((btn) => {
      const contentType = btn.dataset.contentType || 'blog';
      const list = groups.get(contentType) || [];
      list.push(btn);
      groups.set(contentType, list);
    });

    await Promise.all(
      Array.from(groups.entries()).map(async ([contentType, group]) => {
        const slugs = group.map((btn) => btn.dataset.slug || '').filter(Boolean);
        if (!slugs.length) return;
        try {
          const res = await fetch(
            `/api/likes?contentType=${encodeURIComponent(contentType)}&slugs=${encodeURIComponent(
              slugs.join(','),
            )}`,
          );
          if (!res.ok) return;
          const data: LikesResponse = await res.json();
          group.forEach((btn) => {
            const slug = btn.dataset.slug || '';
            setCount(btn, data.likes?.[slug] ?? 0);
          });
        } catch {
          /* 点赞数只是锦上添花，静默失败即可，不影响点赞交互本身 */
        }
      }),
    );
  }

  function initLikeButtons() {
    const buttons = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.like-button[data-like-button]:not([data-bound])'),
    );
    if (!buttons.length) return;
    buttons.forEach((btn) => (btn.dataset.bound = 'true'));

    // 计数只是锦上添花，不阻塞按钮的可点击状态；本机点赞状态（localStorage）
    // 同步读取、立即生效。不展示时跳过初始拉数，仍保留点赞 POST。
    fetchInitialCounts(buttons);

    buttons.forEach((btn) => {
      const key = btn.dataset.storageKey || '';
      const slug = btn.dataset.slug || '';
      const title = btn.dataset.title || '';
      const contentType = (btn.dataset.contentType || 'blog') as ContentType;

      let liked = false;
      try {
        liked = key ? localStorage.getItem(key) === '1' : false;
      } catch {}
      setState(btn, liked);

      btn.addEventListener('click', () => {
        liked = !liked;
        setState(btn, liked);
        setCount(btn, currentCount(btn) + (liked ? 1 : -1));

        btn.classList.remove('is-animating');
        void btn.offsetWidth; // 强制重排，让动画在连续点击时也能重新播放
        btn.classList.add('is-animating');

        try {
          if (key) localStorage.setItem(key, liked ? '1' : '0');
        } catch {}

        const eventProps = { contentType, slug, title, path: location.pathname };
        if (liked) {
          AnalyticsEvents.postLike(eventProps);
        } else {
          AnalyticsEvents.postUnlike(eventProps);
        }

        // 服务端计数是最终真相，返回后用真实值纠正一次本地乐观更新的漂移。
        fetch('/api/likes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, contentType, liked }),
        })
          .then((res) => (res.ok ? (res.json() as Promise<ToggleResponse>) : null))
          .then((data) => {
            if (data) setCount(btn, data.likes);
          })
          .catch(() => {
            /* 点赞数只是锦上添花，静默失败即可 */
          });
      });
    });
  }

  initLikeButtons();
</script>
