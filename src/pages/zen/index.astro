---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface ZenEntry {
  href: string;
  title: string;
  desc: string;
}

// zen/ 下的所有子页面都在这里登记一条，作为这条私人路由的目录。
const entries: ZenEntry[] = [
  {
    href: '/zen/roadmap/',
    title: '能力地图 · 前端 → AI Agent 工程师',
    desc: '一份按长期价值分层、而非按学习顺序排列的私人技能地图：覆盖技术栈与产品化能力两条轴，拆到"过多久还值钱"的坐标系里。',
  },
];
---

<BaseLayout
  title="zen"
  description="一处私人路由：借《禅与摩托车维修的艺术》里的良质，对自己的技术选择与认知习惯做一次保养。"
  noindex={true}
>
  <article class="zen">
    <header class="hero">
      <p class="eyebrow">私人路由 · 不出现在导航与站内搜索里</p>
      <h1>zen</h1>
    </header>

    <div class="prose">
      <p>
        这是我给自己留的一处私人角落，不挂在导航栏，不进 sitemap，只有知道链接的人（也就是我自己）能找到。
      </p>
      <p>
        名字借自罗伯特·波西格的《禅与摩托车维修的艺术》。书里把"良质"（Quality）当成一切判断的起点——它不能被完整定义，却能被清楚地认出来：一辆摩托车修得好不好，一段代码写得对不对，一篇文章有没有说清楚，往往在看到的那一刻就知道，理由是后来才补上的。
      </p>
      <p>
        作者借修摩托车这件具体的事，串起两种理解世界的方式——古典的（拆开、分析、按流程走）和浪漫的（整体地感受、凭直觉判断）。他想说的是，真正的良质从来不是两者中的一个，是两者都到位之后，才显现出来的那个东西。
      </p>
      <p>
        这条路由就是拿这套视角，对着自己的技术选择、职业判断、认知习惯做一次"保养"——不是写给读者看的博客，是写给自己看的检修记录。
      </p>
    </div>

    <section class="index">
      <p class="index-title">目录</p>
      <div class="entries">
        {entries.map((entry) => (
          <a class="entry" href={entry.href}>
            <span class="entry-title">{entry.title}</span>
            <span class="entry-desc">{entry.desc}</span>
          </a>
        ))}
      </div>
    </section>

    <p class="closing">良质不必被证明，只需要被认出来。这条路由存在的意义，就是不断练这份认出来的能力。</p>
  </article>
</BaseLayout>

<style>
  .zen {
    max-width: 640px;
    margin: 0 auto;
  }
  .hero {
    margin-bottom: 2rem;
  }
  .eyebrow {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }
  .hero h1 {
    margin: 0;
    font-size: 2.4rem;
  }
  .prose p {
    margin: 1.25rem 0;
    color: var(--fg-body);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .index {
    margin-top: 3rem;
  }
  .index-title {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }
  .entries {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .entry {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.1rem 1.3rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--paper);
    box-shadow: 3px 3px 0 var(--border);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .entry:hover {
    text-decoration: none;
    border-color: var(--accent);
    transform: translate(-1px, -1px);
  }
  .entry-title {
    color: var(--fg);
    font-weight: 700;
    font-size: 1.05rem;
  }
  .entry-desc {
    color: var(--fg-muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .closing {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--fg-muted);
    font-size: 0.98rem;
    line-height: 1.8;
    text-align: center;
  }
</style>
