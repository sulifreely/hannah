    display: flex;
    flex-direction: column;
  }
  .cap-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.7rem;
  }
  .cap-index {
    font-family: var(--font-mono);
    color: var(--fg-subtle);
    font-size: 0.85rem;
  }
  .cap-title {
    margin: 0 0 0.4rem;
    font-size: 1.08rem;
  }
  .cap-summary {
    margin: 0 0 0.85rem;
    padding: 0.65rem 1rem;
    background: var(--tag-bg);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
    font-size: 0.92rem;
    color: var(--fg);
    line-height: 1.6;
  }
  .cap-layers {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }
  .layer-tag {
    padding: 0.2em 0.6em;
    border-radius: 6px;
    background: var(--code-bg);
    color: var(--fg-muted);
    font-size: 0.78rem;
    font-family: var(--font-mono);
  }
  .ext-link {
    margin-top: auto;
    font-size: 0.85rem;
    color: var(--fg-subtle);
    text-decoration-color: var(--fg-subtle);
  }
  .ext-link:hover {
    color: var(--accent);
  }

  .refs {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .back-link {
    margin: 0;
  }
  .back-link a {
    color: var(--fg-muted);
    text-decoration-color: var(--fg-subtle);
    font-size: 0.95rem;
  }
  .back-link a:hover {
    color: var(--accent);
  }

  .mermaid-wrap {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: center;
  }
  .mermaid-wrap pre.mermaid {
    margin: 0;
    width: 100%;
    max-width: 800px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 1rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--code-bg);
    text-align: center;
    line-height: normal;
    color: transparent;
    font-size: 0;
    min-height: 200px;
  }
  .mermaid-wrap pre.mermaid[data-processed] {
    color: inherit;
    min-height: 0;
  }
  /* svg 是 mermaid.js 运行时注入的，不在 Astro 模板里，
     scoped 选择器加的 data-astro-cid 属性永远匹配不到它，必须用 :global()。 */
  .mermaid-wrap pre.mermaid :global(svg) {
    max-width: 100%;
    height: auto;
  }
  /* 密集的图（技术栈分层、Harness 同心结构）缩到手机宽度时文字会小到读不清，
     改成固定高度＋横向滚动，保持字号，而不是无脑等比缩小。 */
  @media (max-width: 640px) {
    .mermaid-wrap {
      justify-content: flex-start;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin-left: calc(-1 * 24px);
      margin-right: calc(-1 * 24px);
      padding-left: 24px;
      padding-right: 24px;
    }
    .mermaid-wrap pre.mermaid {
      width: max-content;
      max-width: none;
    }
    .mermaid-wrap pre.mermaid :global(svg) {
      max-width: none;
      width: auto;
      height: 220px;
    }
  }
</style>

<script>
  (async function () {
    const blocks = Array.from(document.querySelectorAll<HTMLElement>('pre.mermaid'));
    if (!blocks.length) return;

    blocks.forEach((el, i) => {
      el.dataset.src = el.textContent || '';
      if (!el.id) el.id = 'mermaid-' + i;
    });

    const { default: mermaid } = await import('mermaid');
    const themeName = () =>
      document.documentElement.getAttribute('data-theme') === 'dark'
        ? 'dark'
        : 'neutral';

    async function render() {
      for (const el of blocks) {
        el.removeAttribute('data-processed');
        el.innerHTML = el.dataset.src || '';
      }
      mermaid.initialize({
        startOnLoad: false,
        look: 'handDrawn',
        handDrawnSeed: 1,
        theme: themeName(),
        securityLevel: 'strict',
        fontFamily: '"Comic Neue", "LXGW WenKai Lite", cursive',
      });
      for (const el of blocks) {
        try {
          await mermaid.run({ nodes: [el] });
        } catch (e) {
          el.dataset.processed = 'error';
        }
      }
    }

    await render();

    let last = themeName();
    new MutationObserver(() => {
      const t = themeName();
      if (t !== last) {
        last = t;
        render();
      }
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  })();
</script>
