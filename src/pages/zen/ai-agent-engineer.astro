---
import BaseLayout from '../../layouts/BaseLayout.astro';

type Durability = 'durable' | 'medium' | 'volatile';

const DURABILITY_LABEL: Record<Durability, string> = {
  durable: '持久',
  medium: '中期',
  volatile: '易变',
};

interface LayerRef {
  label: string;
  href: string;
  kind: string; // 资料类型：书 / 课程 / 官方文档 / 文章 / 规范
  gain: string; // 照着学能提升什么
}

interface Layer {
  id: string;
  name: string;
  halfLife: string;
  durability: Durability;
  skills: string[];
  note: string;
  refs: LayerRef[];
}

// 由下（地基，最不容易过时）到上（框架平台，最容易过时）
const layers: Layer[] = [
  {
    id: 'l1',
    name: 'L1 · 地基层：系统工程判断力',
    halfLife: '半衰期：10 年以上',
    durability: 'durable',
    skills: [
      '分布式系统与并发模型',
      'HTTP / WebSocket / Client-Server 架构设计',
      '软件架构与应用设计能力',
      '性能与成本的权衡直觉',
      '需求拆解与工程判断力',
    ],
    note: '这层几乎不因为"AI"这个前缀而改变——它就是好工程师一直在练的东西。如果这层已经扎实，转型 Agent 工程真正要补的，其实只是 L2、L3、L4 三层，不是从零开始。',
    refs: [
      { label: 'Designing Data-Intensive Applications', href: 'https://dataintensive.net/', kind: '书', gain: '建立分布式存储、一致性与可靠性的判断框架' },
      { label: 'MIT 6.824 · Distributed Systems', href: 'https://pdos.csail.mit.edu/6.824/', kind: '课程', gain: '从复制、共识到分区，动手实现分布式系统核心协议' },
    ],
  },
  {
    id: 'l2',
    name: 'L2 · 通用技艺层：Agent 系统的核心工程能力',
    halfLife: '半衰期：3–5 年以上',
    durability: 'durable',
    skills: [
      'Context Engineering（记忆 / 检索 / 压缩的取舍）',
      '工具契约设计（Tool Schema、错误恢复）',
      'Agent 架构模式（ReAct、状态机、Supervisor-Worker）',
      'RAG 系统设计原理（chunking、混合检索、rerank、评估驱动迭代）',
      'MCP / A2A 协议原理（Agent-to-Tool 与 Agent-to-Agent 分层）',
      '评估与可观测性体系（离线评估 + 在线 trace）',
      '安全与治理（最小权限、致命三件套）',
    ],
    note: '这是地图里最值得投入的一层：不依赖任何具体框架，换一次框架、换一次模型，这里学到的判断力原样保留。《Agent 的七笔预算》里拆的感知 / 记忆 / 推理 / 行动 / 反思 / 协作 / 治理，说的就是这一层。',
    refs: [
      { label: 'Anthropic · Building Effective Agents', href: 'https://www.anthropic.com/engineering/building-effective-agents', kind: '文章', gain: '分清工作流与 Agent，掌握常见编排模式的取舍' },
      { label: 'Anthropic · Effective context engineering', href: 'https://www.anthropic.com/engineering/effective-context-engineering-for-ai-agents', kind: '文章', gain: '学会记忆、检索、压缩的上下文管理策略' },
      { label: 'Model Context Protocol · 官方规范', href: 'https://modelcontextprotocol.io', kind: '规范', gain: '吃透 Agent-to-Tool 协议如何设计 schema 与鉴权' },
      { label: 'Simon Willison · The lethal trifecta', href: 'https://simonwillison.net/2025/Jun/16/the-lethal-trifecta/', kind: '文章', gain: '识别致命三件套，建立最小权限的安全直觉' },
      { label: 'OWASP · LLM06:2025 Excessive Agency', href: 'https://owasp.org/www-project-top-10-for-large-language-model-applications/2_0_vulns/LLM06_ExcessiveAgency.html', kind: '规范', gain: '识别过度授权风险，划清 Agent 该有多大权限' },
    ],
  },
  {
    id: 'l3',
    name: 'L3 · 语言与运行时层',
    halfLife: '半衰期：5–10 年，取决于场景',
    durability: 'medium',
    skills: [
      'Python（AI 生态的通用语言，模型侧几乎无可替代）',
      'Go（高并发网关 / Agent 基础设施的默认选择）',
      'TypeScript（已有资产，前端到 Agent UI 的桥梁）',
    ],
    note: 'Python 和 Go 常常同时出现，不是凑数：Python 管"模型怎么想"，Go 管"系统怎么扛"——Ollama、Weaviate、Temporal、GitHub 官方 MCP Server 都是 Go 写的，两者是分工，不是二选一。',
    refs: [
      { label: 'Python · asyncio 官方文档', href: 'https://docs.python.org/3/library/asyncio.html', kind: '官方文档', gain: '掌握异步并发，写出模型侧高吞吐的 IO 代码' },
      { label: 'Effective Go', href: 'https://go.dev/doc/effective_go', kind: '官方文档', gain: '写出地道的 Go 并发代码，扛住网关级高并发' },
    ],
  },
  {
    id: 'l4',
    name: 'L4 · 框架与平台层',
    halfLife: '半衰期：0.5–2 年',
    durability: 'volatile',
    skills: [
      'LangChain / LangGraph（链式 / 图状态编排）',
      'LlamaIndex（检索与索引）',
      'AutoGen（多智能体对话）',
      'CrewAI（角色化多智能体）',
      'Dify / LangFlow（可视化编排平台）',
      'Llama 等开源模型的本地部署',
    ],
    note: '这一层的价值是"练手感"，不是"建护城河"。同时收集五六个框架，容易停留在"还没形成判断"，而不是"见多识广"——选一个吃透，其余的知道边界在哪、什么时候该换，就够了。',
    refs: [
      { label: 'LangGraph · 官方文档', href: 'https://langchain-ai.github.io/langgraph/', kind: '官方文档', gain: '用显式状态机建模可控、可恢复的 Agent 流程' },
      { label: 'LlamaIndex · 官方文档', href: 'https://docs.llamaindex.ai/', kind: '官方文档', gain: '快速搭起 RAG 的检索与索引基线' },
    ],
  },
];

interface Capability {
  title: string;
  summary: string;
  layerTags: string[];
  durability: Durability | 'mixed';
  note: string;
  link?: { href: string; label: string };
  refs: LayerRef[];
}

const capabilities: Capability[] = [
  {
    title: '产品思维',
    summary: '怎么打造一个好产品——需求判断、价值排序、功能与噪声的取舍',
    layerTags: ['L1 地基层'],
    durability: 'durable',
    note: '这层完全不因为"AI"这个前缀改变。AI 只是让"做出来"的成本变低了，"该不该做、做成什么样"的判断反而更值钱——这也是本文开头那张坐标图里，横轴之外真正稀缺的东西。',
    refs: [
      { label: 'Marty Cagan · INSPIRED', href: 'https://www.svpg.com/books/inspired-how-to-create-tech-products-customers-love-2nd-edition/', kind: '书', gain: '建立"价值 · 可用性 · 商业可行性"三位一体的产品判断框架' },
      { label: 'Shreyas Doshi · Why Product Sense Is the Only Product Skill That Will Matter in the AI Age', href: 'https://shreyasdoshi.substack.com/p/why-product-sense-is-the-only-product', kind: '文章', gain: '理解 AI 拉平执行力之后，判断力为何变得更稀缺' },
    ],
  },
  {
    title: 'AI Agent 产品体验',
    summary: '把 Prompt、Tool、编排这些 AI 能力，封装成用户可配置、可信任的产品交互',
    layerTags: ['L2 通用技艺层'],
    durability: 'durable',
    note: '用户不会写提示词，也不该被要求写提示词。好的 Agent 产品要把提示词工程、工具选择、编排逻辑这些工程细节，翻译成看得懂、配得动、能验证的界面——表单、卡片、可解释的中间结果。',
    link: { href: '/talks/agent-hitl-vs-yolo/', label: 'Agent 的 HITL 与 YOLO' },
    refs: [
      { label: 'Google PAIR · People + AI Guidebook', href: 'https://pair.withgoogle.com/guidebook/', kind: '指南', gain: '覆盖数据、可解释性、信任校准的人机协作设计模式全集' },
      { label: 'Microsoft Research · Guidelines for Human-AI Interaction', href: 'https://www.microsoft.com/en-us/research/project/guidelines-for-human-ai-interaction/', kind: '规范', gain: '18 条基于 20 年研究的循证准则，覆盖初次使用、出错、长期使用等场景' },
    ],
  },
  {
    title: '端到端全栈交付',
    summary: '前端 → 状态 → 服务 → 数据，打通完整链路的能力',
    layerTags: ['L1 地基层', 'L3 语言运行时层'],
    durability: 'durable',
    note: '不需要每一层都是专家，但要有能力在出问题时知道"锅在哪一层"，能自己动手把链路跑通，而不是永远等别人。',
    link: { href: '/blog/state-management-kernel-and-forks/', label: '一个内核，三种分歧：重新理解前端状态管理' },
    refs: [
      { label: 'Ryan Singer · Shape Up', href: 'https://basecamp.com/shapeup', kind: '书', gain: '学会拆解、下注、限定周期，把一个想法端到端交付成产品' },
      { label: 'The Twelve-Factor App', href: 'https://12factor.net/', kind: '方法论', gain: '一套从本地开发到生产部署都适用的云原生应用准则' },
    ],
  },
  {
    title: 'Agent 运行时与生态',
    summary: 'Agent 执行循环、Tool / MCP、Skill / Plugin、多 Agent 协作与编排模式',
    layerTags: ['L2 通用技艺层'],
    durability: 'mixed',
    note: '这部分内容基本就是前面 L2 通用技艺层拆过的东西，放在产品视角下再看一遍要多问一句：这套编排，用户能感知到、能信任吗？纯技术视角只关心"能不能跑通"，产品视角还要关心"跑通之后，人愿不愿意把决定权交出去"。',
    link: { href: '/talks/execution-topology-in-skills/', label: '浅谈 Skill 中的执行拓扑' },
    refs: [
      { label: 'Chip Huyen · Agents（摘自 AI Engineering）', href: 'https://huyenchip.com/2025/01/07/agents.html', kind: '文章', gain: '系统梳理规划、工具调用、记忆与失败模式，产品视角审视这套编排是否可信' },
      { label: 'Anthropic · How we built our multi-agent research system', href: 'https://www.anthropic.com/engineering/multi-agent-research-system', kind: '文章', gain: 'orchestrator-worker 生产级多智能体架构的一线工程复盘' },
    ],
  },
  {
    title: 'AI 原生研发流程',
    summary: '探索 AI Coding、自动化验证、端到端调试，提升个人与团队效率',
    layerTags: ['L1 地基层'],
    durability: 'durable',
    note: '不是"会用 Cursor / Claude Code"这么简单，是知道什么该交给 AI、什么必须自己判断，怎么给 agent 立护栏、怎么让验证自动化、怎么在它出错时快速定位是哪一层错了。这件事本身就是这张地图想传达的态度的具体实践。',
    link: { href: '/blog/cognitive-surrender/', label: '解读《Cognitive Surrender》：AI 时代中的认知投降' },
    refs: [
      { label: 'Addy Osmani · Beyond Vibe Coding: From Coder to AI-Era Developer', href: 'https://www.oreilly.com/library/view/beyond-vibe-coding/9798341634749/', kind: '书', gain: '系统学习如何审查、验证、整合 AI 生成代码，而不只是"感觉良好"地生成' },
      { label: 'Simon Willison · Designing agentic loops', href: 'https://simonwillison.net/2025/Sep/30/designing-agentic-loops/', kind: '文章', gain: '学会为 agent 设计工具与循环边界，判断什么任务值得交给 agentic loop' },
    ],
  },
];

// 两条轴的二维坐标：技术能力 × 产品能力，四个象限各自的定位
interface Quadrant {
  tag: string;
  name: string;
  desc: string;
  star?: boolean;
}

// 顺序对应 2x2 网格的阅读顺序：左上、右上、左下、右下
const quadrants: Quadrant[] = [
  { tag: '产品强 · 技术弱', name: '有想法，落不了地', desc: '看得懂用户要什么，但受限于工程能力，做不出可用的东西，或做出来扛不住真实流量。' },
  { tag: '产品强 · 技术强', name: '务实的浪漫', desc: '技术是护城河，产品判断是方向感。既能把系统做扎实，又清楚这套能力该为谁、解决什么问题——真正稀缺的位置。', star: true },
  { tag: '产品弱 · 技术弱', name: '工具的搬运工', desc: '停留在"会调 API、会拼框架"，既没沉下去建护城河，也没抬头看做的东西有没有人用。' },
  { tag: '产品弱 · 技术强', name: '精密的自嗨', desc: '架构漂亮、协议吃透，却没人愿意用——技术能解决"怎么做"，解决不了"值不值得做"。' },
];

// 学习目标 1：Agent 设计模式 —— 认知功能（行）× 执行拓扑（列）的正交矩阵
interface PatternCell {
  zh: string;
  en: string;
  star?: boolean; // 最常用、最值得先吃透的模式
}

const patternCols: string[] = ['链式 Chain', '并行 Parallel', '路由 Route', '循环 Loop', '编排 Orchestrate', '层级 Hierarchy'];
const patternRows: { zh: string; en: string }[] = [
  { zh: '感知', en: 'Perception' },
  { zh: '记忆', en: 'Memory' },
  { zh: '推理', en: 'Reasoning' },
  { zh: '行动', en: 'Action' },
  { zh: '反思', en: 'Reflection' },
  { zh: '协作', en: 'Collaboration' },
  { zh: '治理', en: 'Governance' },
];
// [行][列]，null 表示这个交点没有成熟模式
const patternCells: (PatternCell | null)[][] = [
  [{ zh: '语义压缩', en: 'Semantic Compaction' }, { zh: '多模态融合', en: 'Multi-Modal Fusion' }, { zh: '上下文分诊', en: 'Context Triage' }, null, { zh: '渐进发现', en: 'Progressive Discovery', star: true }, null],
  [{ zh: 'RAG 管线', en: 'RAG Pipeline' }, null, { zh: '分层保留', en: 'Hierarchical Retention' }, { zh: '失败日记', en: 'Failure Journal', star: true }, { zh: '进度追踪', en: 'Progress Tracking', star: true }, null],
  [{ zh: '思维链', en: 'Chain-of-Thought' }, { zh: '并行探索', en: 'Parallel Exploration' }, { zh: '复杂度路由', en: 'Complexity Routing' }, { zh: '迭代假设', en: 'Iterative Hypothesis', star: true }, null, null],
  [{ zh: '提示链', en: 'Prompt Chaining' }, null, { zh: '工具调度', en: 'Tool Dispatch' }, null, { zh: '规划执行', en: 'Plan-and-Execute' }, { zh: '守卫三明治', en: 'Guard Sandwich' }],
  [{ zh: '生成-批评', en: 'Generator-Critic' }, null, { zh: '技能包', en: 'Skill Package', star: true }, { zh: '自愈循环', en: 'Self-Heal Loop' }, null, { zh: '经验回放', en: 'Experience Replay' }],
  [{ zh: '交接链', en: 'Handoff Chain' }, { zh: '扇出聚合', en: 'Fan-out / Gather' }, null, { zh: '对抗评审', en: 'Adversarial Review' }, null, { zh: '层级委派', en: 'Hierarchical Delegation' }],
  [null, { zh: '渐进承诺', en: 'Progressive Commitment', star: true }, { zh: '审批门控', en: 'Approval Gate', star: true }, null, { zh: '可观测性', en: 'Observability Harness', star: true }, { zh: '爆炸半径控制', en: 'Blast Radius Control', star: true }],
];

// 两个进阶目标各自的权威资料
const patternRefs: LayerRef[] = [
  { label: 'Anthropic · Building Effective Agents', href: 'https://www.anthropic.com/engineering/building-effective-agents', kind: '文章', gain: '吃透链式 / 路由 / 并行 / 编排等基础模式的取舍' },
  { label: '12-Factor Agents', href: 'https://github.com/humanlayer/12-factor-agents', kind: '仓库', gain: '把 Agent 当正经软件工程来做的 12 条原则' },
];
const harnessRefs: LayerRef[] = [
  { label: 'Thorsten Ball · How to Build an Agent', href: 'https://ampcode.com/how-to-build-an-agent', kind: '文章', gain: '几百行代码从 0 跑通一个能用的 coding agent' },
  { label: 'Anthropic · Building Effective Agents', href: 'https://www.anthropic.com/engineering/building-effective-agents', kind: '文章', gain: 'harness 里编排与工具设计的官方建议' },
  { label: 'Model Context Protocol · 官方规范', href: 'https://modelcontextprotocol.io', kind: '规范', gain: '把工具层做成标准协议，而非硬编码' },
  { label: 'Anthropic · Claude Code: Best practices for agentic coding', href: 'https://www.anthropic.com/engineering/claude-code-best-practices', kind: '文章', gain: '官方一线的 agentic coding harness 实践经验' },
];

function durabilityClass(d: Durability | 'mixed'): string {
  if (d === 'mixed') return 'tag-mixed';
  return `tag-${d}`;
}

function durabilityLabel(d: Durability | 'mixed'): string {
  if (d === 'mixed') return '分层混合';
  return DURABILITY_LABEL[d];
}
---

<BaseLayout
  title="AI Agent 工程师"
  description="AI Agent 工程师的能力地图：按长期价值分层，覆盖技术栈与产品化能力两条轴。"
  noindex={true}
>
  <div class="breakout">
    <div class="shell">
      <header class="hero">
        <p class="eyebrow"><a href="/zen/">zen</a> · 能力地图</p>
        <h1>AI Agent 工程师</h1>
        <p class="lead">
          AI Agent 工程师的能力可以拆成两条轴：<strong>技术轴</strong>按长期价值分层，回答"什么值得深耕、什么只是练手"；<strong>产品轴</strong>衡量"做出来的东西，有没有人愿意用"。这份地图沿这两条轴展开——框架会换、协议会迭代，但底下"系统怎么设计、判断怎么下"那层，不因下一个模型发布而贬值。
        </p>
        <p class="meta-note">写于 2026-07-12，随认知更新，不追求一次写对。</p>
      </header>

      <section class="section">
        <h2>两条轴，一张坐标</h2>
        <p class="section-intro">
          技术轴解决"怎么做得对"，产品轴解决"值不值得做、做成什么样"。两条轴各自都能拉开差距，但真正稀缺的是<strong>右上角</strong>——技术扎实，又清楚自己在为谁解决什么问题。
        </p>
        <div class="quad-legend">
          {quadrants.map((q) => (
            <div class="quad-legend-item">
              <span class={q.star ? 'quad-tag quad-tag-star' : 'quad-tag'}>{q.tag}</span>
              <p class="quad-name">{q.name}</p>
              <p class="quad-desc">{q.desc}</p>
            </div>
          ))}
        </div>
        <div class="axis-cards">
          <div class="axis-card">
            <span class="axis-index">第一条轴</span>
            <h3>技术轴 · 按长期价值分层</h3>
            <p>L1 地基 → L2 通用技艺 → L3 语言运行时 → L4 框架平台，越往下越持久、越是护城河。下面「技术栈：能力分层」一节展开。</p>
          </div>
          <div class="axis-card">
            <span class="axis-index">第二条轴</span>
            <h3>产品轴 · 让能力被人用起来</h3>
            <p>把 Prompt、Tool、编排这些能力，翻译成用户配得动、信得过的产品。下面「产品化能力：地图的第二条轴」一节展开。</p>
          </div>
        </div>
      </section>

      <section class="section">
        <h2>技术栈：能力分层（第一条轴）</h2>
        <div class="mermaid-wrap">
          <pre class="mermaid">
flowchart TB
    accTitle: 技术栈能力分层图
    accDescr: 由上至下四层：L4 框架与平台层，半衰期 0.5 到 2 年；L3 语言与运行时层，半衰期 5 到 10 年；L2 通用技艺层，半衰期 3 到 5 年以上；L1 地基层，半衰期 10 年以上。箭头由上层指向下层，表示上层构建在下层之上，越往下越持久、越是护城河。
    subgraph L4["L4 框架与平台层 · 0.5–2 年 · 易变 / 练手感"]
        direction LR
        L4a["LangChain / LangGraph"] ~~~ L4b["LlamaIndex"] ~~~ L4c["AutoGen / CrewAI"] ~~~ L4d["Dify / LangFlow"]
    end
    subgraph L3["L3 语言与运行时层 · 5–10 年 · 中期 / 工具选择"]
        direction LR
        L3a["Python · 模型怎么想"] ~~~ L3b["Go · 系统怎么扛"] ~~~ L3c["TypeScript · Agent UI 桥梁"]
    end
    subgraph L2["L2 通用技艺层 · 3–5 年 · 护城河 / 最值得投入"]
        direction LR
        L2a["Context Engineering"] ~~~ L2b["Tool 契约 · Agent 架构"] ~~~ L2c["RAG · MCP / A2A"] ~~~ L2d["评估可观测 · 安全治理"]
    end
    subgraph L1["L1 地基层 · 10 年+ · 护城河 / 好工程师的底子"]
        direction LR
        L1a["分布式系统与并发"] ~~~ L1b["软件架构与设计"] ~~~ L1c["性能与成本权衡"] ~~~ L1d["需求拆解 · 工程判断"]
    end
    L4 ==>|"上层构建在下层之上"| L3
    L3 ==> L2
    L2 ==> L1
          </pre>
        </div>
        <p class="section-intro">
          按<strong>半衰期</strong>分层，不按学习顺序排：越往下越不易过时、越难速成，是护城河；越往上越快出效果、越需常刷新，是练手感。每层下方附官方文档与权威文章，可直接参考进行学习。
        </p>
        <div class="legend">
          <span class="tag tag-durable">持久</span>
          <span class="tag tag-medium">中期</span>
          <span class="tag tag-volatile">易变</span>
        </div>

        <div class="stack">
          {[...layers].reverse().map((layer) => (
            <div class={`layer layer-${layer.durability}`} id={layer.id}>
              <div class="layer-head">
                <h3>{layer.name}</h3>
                <span class={`tag ${durabilityClass(layer.durability)}`}>{layer.halfLife}</span>
              </div>
              <ul class="chips">
                {layer.skills.map((skill) => (
                  <li>{skill}</li>
                ))}
              </ul>
              <p class="layer-note">{layer.note}</p>
              <div class="layer-refs">
                <p class="layer-refs-title">权威学习资料👇</p>
                <ul>
                  {layer.refs.map((ref) => (
                    <li class="ref-item">
                      <div class="ref-line">
                        <span class="ref-kind">{ref.kind}</span>
                        <a href={ref.href} target="_blank" rel="noopener noreferrer">{ref.label}</a>
                      </div>
                      <p class="ref-gain">{ref.gain}</p>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>进阶目标一 · 掌握 Agent 设计模式</h2>
        <p class="section-intro">
          L2 通用技艺再往深走，是一套<strong>正交的设计模式框架</strong>：纵轴是 Agent 的七种认知功能（感知 → 治理），横轴是六种执行拓扑（链式 → 层级）。两轴一交叉，就定位到一个具体模式。带 <span class="star-inline">★</span> 的是最常用、最该先吃透的几个。表格比流程图更适合它——因为要表达的是"哪些组合有成熟解法、哪些还是空白"这层关系。
        </p>
        <div class="matrix-scroll">
          <table class="pattern-matrix">
            <thead>
              <tr>
                <th class="corner"><span class="corner-y">认知功能</span><span class="corner-x">执行拓扑</span></th>
                {patternCols.map((col) => (
                  <th class="col-head">{col}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {patternRows.map((row, r) => (
                <tr>
                  <th class="row-head">
                    <span class="row-zh">{row.zh}</span>
                    <span class="row-en">{row.en}</span>
                  </th>
                  {patternCells[r].map((cell) => (
                    <td class={cell ? (cell.star ? 'cell cell-star' : 'cell') : 'cell cell-empty'}>
                      {cell ? (
                        <>
                          <span class="cell-zh">{cell.zh}{cell.star && <span class="star-inline">★</span>}</span>
                          <span class="cell-en">{cell.en}</span>
                        </>
                      ) : (
                        <span class="cell-dash">–</span>
                      )}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="matrix-note">
          不必背下每一格。真正的用法是：遇到一个 Agent 需求，先问"它卡在哪个认知功能上"，再问"该用哪种拓扑组织"，两轴一交叉，模式自己就浮出来了。
        </p>
        <div class="layer-refs standalone-refs">
          <p class="layer-refs-title">权威学习资料👇</p>
          <ul>
            {patternRefs.map((ref) => (
              <li class="ref-item">
                <div class="ref-line">
                  <span class="ref-kind">{ref.kind}</span>
                  <a href={ref.href} target="_blank" rel="noopener noreferrer">{ref.label}</a>
                </div>
                <p class="ref-gain">{ref.gain}</p>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="section">
        <h2>进阶目标二 · 从 0 到 1 实现一个 Agent Harness</h2>
        <p class="section-intro">
          真正拉开差距的认知是：<strong>模型只占约 10%，剩下 90% 是包在它外面的 harness</strong>——模型是引擎，harness 才是车、是路、是交通规则。下图把一个基本 harness 拆成四层，由下到上层层加固：最底层是核心原语，最顶层是让它跑在生产上的运维外壳。能把这张图从 0 到 1 亲手实现一遍，L2 这层才算真正落地。
        </p>
        <div class="mermaid-wrap">
          <pre class="mermaid">
flowchart TB
    accTitle: Agent Harness 结构解剖图
    accDescr: 由下到上四层结构：最底层是核心原语，Message 会话记录、LLM、Model Provider 抽象；往上一层是 Agent 循环，think-act-observe 循环、工具定义与并行派发、中间件与生命周期钩子、权限审批与结果裁剪；再往上是开发者接口，CLI TUI 交互、库 API 入口、分层配置与 Settings；最上层是运行与运维，会话记忆存储、部署与伸缩配置、评估与测试、可观测与 Tracing。箭头由上层指向下层，表示上层构建在下层之上。
    subgraph H4["④ 运行与运维 · 让它跑在生产上"]
        direction LR
        H4a["会话 / 记忆存储"] ~~~ H4b["部署与伸缩配置"] ~~~ H4c["评估与测试"] ~~~ H4d["可观测 / Tracing"]
    end
    subgraph H3["③ 开发者接口 · 让人用得上"]
        direction LR
        H3a["CLI / TUI 交互"] ~~~ H3b["库 API 入口"] ~~~ H3c["分层配置与 Settings"]
    end
    subgraph H2["② Agent 循环 · 让它动起来"]
        direction LR
        H2a["think → act → observe 循环"] ~~~ H2b["工具定义与并行派发"] ~~~ H2c["中间件 / 生命周期钩子"] ~~~ H2d["权限审批 · 结果裁剪"]
    end
    subgraph H1["① 核心原语 · 稳定基座"]
        direction LR
        H1a["Message 会话记录"] ~~~ H1b(("LLM")) ~~~ H1c["Model / Provider 抽象"]
    end
    H4 ==>|"上层构建在下层之上"| H3
    H3 ==> H2
    H2 ==> H1
          </pre>
        </div>
        <p class="matrix-note">
          越靠下越稳定、越该先写：先有 Message + Model 抽象（换 provider 不改上层），再套 think-act-observe 循环，然后才是审批、CLI、可观测这些上层。参考实现证明这套结构几百行就能跑通——难的不是写出来，是想清楚每一层的边界。
        </p>
        <div class="layer-refs standalone-refs">
          <p class="layer-refs-title">权威学习资料👇</p>
          <ul>
            {harnessRefs.map((ref) => (
              <li class="ref-item">
                <div class="ref-line">
                  <span class="ref-kind">{ref.kind}</span>
                  <a href={ref.href} target="_blank" rel="noopener noreferrer">{ref.label}</a>
                </div>
                <p class="ref-gain">{ref.gain}</p>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="section">
        <h2>产品化能力：地图的第二条轴（产品轴）</h2>
        <p class="section-intro">
          技术栈之外，同样值得长期投入的另一条轴——产品判断力。协议都懂，也可能做不出一个让人愿意用的产品。
        </p>
        <div class="cap-grid">
          {capabilities.map((cap, i) => (
            <article class="cap-card">
              <div class="cap-head">
                <span class="cap-index">{String(i + 1).padStart(2, '0')}</span>
                <span class={`tag ${durabilityClass(cap.durability)}`}>{durabilityLabel(cap.durability)}</span>
              </div>
              <h3 class="cap-title">{cap.title}</h3>
              <p class="cap-summary">{cap.summary}</p>
              <div class="cap-layers">
                {cap.layerTags.map((tag) => (
                  <span class="layer-tag">{tag}</span>
                ))}
              </div>
              <div class="layer-refs">
                <p class="layer-refs-title">权威学习资料👇</p>
                <ul>
                  {cap.refs.map((ref) => (
                    <li class="ref-item">
                      <div class="ref-line">
                        <span class="ref-kind">{ref.kind}</span>
                        <a href={ref.href} target="_blank" rel="noopener noreferrer">{ref.label}</a>
                      </div>
                      <p class="ref-gain">{ref.gain}</p>
                    </li>
                  ))}
                </ul>
              </div>
              {cap.link && (
                <a class="ext-link" href={cap.link.href}>延伸阅读：{cap.link.label}</a>
              )}
            </article>
          ))}
        </div>
      </section>

      <footer class="refs">
        <p class="back-link"><a href="/zen/">← 回到 zen</a></p>
      </footer>
    </div>
  </div>
</BaseLayout>

