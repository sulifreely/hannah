---
import BaseLayout from '../../layouts/BaseLayout.astro';

type Durability = 'durable' | 'medium' | 'volatile';

const DURABILITY_LABEL: Record<Durability, string> = {
  durable: '持久',
  medium: '中期',
  volatile: '易变',
};

interface Layer {
  id: string;
  name: string;
  halfLife: string;
  durability: Durability;
  skills: string[];
  note: string;
}

// 由下（地基，最不容易过时）到上（框架平台，最容易过时）
const layers: Layer[] = [
  {
    id: 'l1',
    name: 'L1 · 地基层：系统工程判断力',
    halfLife: '半衰期：10 年以上',
    durability: 'durable',
    skills: [
      '分布式系统与并发模型',
      'HTTP / WebSocket / Client-Server 架构设计',
      '软件架构与应用设计能力',
      '性能与成本的权衡直觉',
      '需求拆解与工程判断力',
    ],
    note: '这层几乎不因为"AI"这个前缀而改变——它就是好工程师一直在练的东西。如果这层已经扎实，转型 Agent 工程真正要补的，其实只是 L2、L3、L4 三层，不是从零开始。',
  },
  {
    id: 'l2',
    name: 'L2 · 通用技艺层：Agent 系统的核心工程能力',
    halfLife: '半衰期：3–5 年以上',
    durability: 'durable',
    skills: [
      'Context Engineering（记忆 / 检索 / 压缩的取舍）',
      '工具契约设计（Tool Schema、错误恢复）',
      'Agent 架构模式（ReAct、状态机、Supervisor-Worker）',
      'RAG 系统设计原理（chunking、混合检索、rerank、评估驱动迭代）',
      'MCP / A2A 协议原理（Agent-to-Tool 与 Agent-to-Agent 分层）',
      '评估与可观测性体系（离线评估 + 在线 trace）',
      '安全与治理（最小权限、致命三件套）',
    ],
    note: '这是地图里最值得投入的一层：不依赖任何具体框架，换一次框架、换一次模型，这里学到的判断力原样保留。《Agent 的七笔预算》里拆的感知 / 记忆 / 推理 / 行动 / 反思 / 协作 / 治理，说的就是这一层。',
  },
  {
    id: 'l3',
    name: 'L3 · 语言与运行时层',
    halfLife: '半衰期：5–10 年，取决于场景',
    durability: 'medium',
    skills: [
      'Python（AI 生态的通用语言，模型侧几乎无可替代）',
      'Go（高并发网关 / Agent 基础设施的默认选择）',
      'TypeScript（已有资产，前端到 Agent UI 的桥梁）',
    ],
    note: 'Python 和 Go 常常同时出现，不是凑数：Python 管"模型怎么想"，Go 管"系统怎么扛"——Ollama、Weaviate、Temporal、GitHub 官方 MCP Server 都是 Go 写的，两者是分工，不是二选一。',
  },
  {
    id: 'l4',
    name: 'L4 · 框架与平台层',
    halfLife: '半衰期：0.5–2 年',
    durability: 'volatile',
    skills: [
      'LangChain / LangGraph（链式 / 图状态编排）',
      'LlamaIndex（检索与索引）',
      'AutoGen（多智能体对话）',
      'CrewAI（角色化多智能体）',
      'Dify / LangFlow（可视化编排平台）',
      'Llama 等开源模型的本地部署',
    ],
    note: '这一层的价值是"练手感"，不是"建护城河"。同时收集五六个框架，容易停留在"还没形成判断"，而不是"见多识广"——选一个吃透，其余的知道边界在哪、什么时候该换，就够了。',
  },
];

interface Capability {
  title: string;
  summary: string;
  layerTags: string[];
  durability: Durability | 'mixed';
  note: string;
  link?: { href: string; label: string };
}

const capabilities: Capability[] = [
  {
    title: '产品思维',
    summary: '怎么打造一个好产品——需求判断、价值排序、功能与噪声的取舍',
    layerTags: ['L1 地基层'],
    durability: 'durable',
    note: '这层完全不因为"AI"这个前缀改变。AI 只是让"做出来"的成本变低了，"该不该做、做成什么样"的判断反而更值钱——技术能解决"怎么做"，解决不了"值不值得做"。',
  },
  {
    title: 'AI Agent 产品体验',
    summary: '把 Prompt、Tool、编排这些 AI 能力，封装成用户可配置、可信任的产品交互',
    layerTags: ['L2 通用技艺层', '前端优势'],
    durability: 'durable',
    note: '用户不会写提示词，也不该被要求写提示词。好的 Agent 产品要把提示词工程、工具选择、编排逻辑这些工程细节，翻译成看得懂、配得动、能验证的界面——表单、卡片、可解释的中间结果。这恰好是很多纯后端出身的 AI 工程师的短板，也是前端工程师最容易直接接手的部分。',
    link: { href: '/talks/agent-hitl-vs-yolo/', label: 'Agent 的 HITL 与 YOLO' },
  },
  {
    title: '端到端全栈交付',
    summary: '前端 → 状态 → 服务 → 数据，打通完整链路的能力',
    layerTags: ['L1 地基层', 'L3 语言运行时层'],
    durability: 'durable',
    note: '不需要每一层都是专家，但要有能力在出问题时知道"锅在哪一层"，能自己动手把链路跑通，而不是永远等别人。界面状态和服务状态怎么对齐，这个判断本身就是前端工程师的老本行。',
    link: { href: '/blog/state-management-kernel-and-forks/', label: '一个内核，三种分歧：重新理解前端状态管理' },
  },
  {
    title: 'Agent 运行时与生态',
    summary: 'Agent 执行循环、Tool / MCP、Skill / Plugin、多 Agent 协作与编排模式',
    layerTags: ['L2 通用技艺层'],
    durability: 'mixed',
    note: '这部分内容基本就是前面 L2 通用技艺层拆过的东西，放在产品视角下再看一遍要多问一句：这套编排，用户能感知到、能信任吗？纯技术视角只关心"能不能跑通"，产品视角还要关心"跑通之后，人愿不愿意把决定权交出去"。',
    link: { href: '/talks/execution-topology-in-skills/', label: '浅谈 Skill 中的执行拓扑' },
  },
  {
    title: 'AI 原生研发流程',
    summary: '探索 AI Coding、自动化验证、端到端调试，提升个人与团队效率',
    layerTags: ['L1 地基层'],
    durability: 'durable',
    note: '不是"会用 Cursor / Claude Code"这么简单，是知道什么该交给 AI、什么必须自己判断，怎么给 agent 立护栏、怎么让验证自动化、怎么在它出错时快速定位是哪一层错了。这件事本身就是这张地图想传达的态度的具体实践。',
    link: { href: '/blog/cognitive-surrender/', label: '解读《Cognitive Surrender》：AI 时代中的认知投降' },
  },
];

interface Advantage {
  from: string;
  to: string;
  note: string;
  link?: { href: string; label: string };
}

const advantages: Advantage[] = [
  {
    from: '状态管理经验',
    to: 'Agent 记忆与上下文管理',
    note: '"状态从哪来、该在哪层收敛"，和 Agent 的"什么该放进 context、什么该换出到外部存储"是同一个决策模型。',
    link: { href: '/blog/state-management-kernel-and-forks/', label: '一个内核，三种分歧：重新理解前端状态管理' },
  },
  {
    from: '前端性能预算直觉',
    to: 'Agent 认知预算模型',
    note: '掉帧、卡顿、崩溃的直觉，可以原样迁移到感知 / 记忆 / 推理 / 行动 / 反思 / 协作 / 治理这七笔预算上。',
    link: { href: '/blog/agent-cognitive-budgets/', label: 'Agent 的七笔预算' },
  },
  {
    from: '异步与 API 集成经验',
    to: '工具调用、流式响应与失败恢复',
    note: 'async/await、防抖节流、错误边界，直接对应 Agent 的工具调用重试、流式 token 处理、失败降级。',
  },
  {
    from: '工作流编排设计经验',
    to: '多智能体协作模式的选型判断',
    note: '链式、并行、路由、循环、编排、层级——这套模式与 Supervisor-Worker 型多智能体系统在结构上是同一件事。',
    link: { href: '/talks/execution-topology-in-skills/', label: '浅谈 Skill 中的执行拓扑' },
  },
  {
    from: '产品侧的确认机制直觉',
    to: 'Agent 治理与 HITL / YOLO 设计',
    note: '删除要二次确认、查看不用确认——同一套风险分层逻辑，搬到 Agent 的自主程度设计上是一模一样的问题。',
    link: { href: '/talks/agent-hitl-vs-yolo/', label: 'Agent 的 HITL 与 YOLO' },
  },
  {
    from: 'UI / UX 审美',
    to: '思考过程可视化、Streaming 界面',
    note: '大多数纯后端出身的 AI 工程师做不好这件事——这是少数能立刻变现、不需要额外学习的差异化优势。',
  },
];

interface Phase {
  title: string;
  goal: string;
  actions: string[];
  deliverable: string;
  pitfall: string;
}

const phases: Phase[] = [
  {
    title: '阶段一 · 打地基',
    goal: '把"读懂 Agent 论文和博客"变成"能读懂并写出可运行的最小系统"。',
    actions: [
      'Python 工程化：类型标注（Pydantic）、asyncio、包管理——不是"能写脚本"，是"能写别人能维护的模块"。',
      '抛开框架，直接裸调用 LLM API：手写 function calling、streaming、结构化输出，决定了之后用任何框架时，是"理解原理选工具"还是"依赖工具的人"。',
      '用 Go 写第一个真正的用途：一个最小的 LLM 网关（转发请求、限流、SSE 流式转发）——直接体会 Python 和 Go 在系统里的分工差异。',
    ],
    deliverable: '一个不依赖任何 Agent 框架、纯手写的工具调用循环 + 一个 Go 写的最小反向代理。',
    pitfall: '直接从 LangChain 教程入门——只会学到"怎么调 LangChain"，学不到"Agent 循环为什么要这样设计"。',
  },
  {
    title: '阶段二 · 长出骨架',
    goal: '从"单次调用"到"能落地的系统"：RAG + 一个 Agent 框架 + 协议实操。',
    actions: [
      'RAG 按顺序加：先有能跑的向量检索基线，再加 chunking 策略、混合检索（BM25 + 向量）、rerank，最后补一套评估——顺序很重要，否则优化无对照。',
      '选一个 Agent 框架吃透：LangGraph 的显式状态机建模，是当前对"确定性、可控性"要求下最主流的选择；LlamaIndex 更适合当 RAG 阶段的工具，而非 Agent 主框架。',
      'MCP 实操：写一个真正的 MCP Server，接入 Claude Desktop / Cursor，理解 Agent-to-Tool 这层协议怎么设计 schema、怎么做鉴权。',
      '同步想清楚这套能力最终要包成什么样的产品交互，而不是只停留在"能跑的脚本"。',
    ],
    deliverable: '一个带评估集的 RAG 助手 + 一个自定义 MCP Server + 一个用 LangGraph 写的、有状态、能处理失败重试的 Agent。',
    pitfall: '同时学五个框架——"框架收集"容易带来虚假的安全感，实际形成不了判断力。',
  },
  {
    title: '阶段三 · 生产化与治理',
    goal: '让 Agent 系统"在没人看着的周二也能正常运行"。',
    actions: [
      '评估体系：离线评估（Ragas / Promptfoo）+ 在线可观测性（LangSmith / Langfuse / Arize），为 Agent 建 CI——质量回归要能在合并前被拦下来。',
      '多智能体：理解 Supervisor-Worker、并行探索与共享产物协作两种模式的适用边界，用 CrewAI 或 LangGraph 的 supervisor 模式实践一次即可。',
      '协议深化：MCP 之上补 A2A（多智能体协调层），理解两层协议的分工，为跨系统的 Agent 协作做准备。',
      '部署运维：容器化、成本与延迟监控、模型路由（简单问题用便宜模型）、失败降级。',
      'AI 原生工作流：给日常写代码的流程加一层自动化验证，把阶段三的评估思路用在自己身上。',
    ],
    deliverable: '把阶段二的项目接上评估 CI、可观测性，加一次真实的多智能体协作 + 部署上线，观察真实的 P99 与成本曲线。',
    pitfall: '把"能跑 demo"当成"生产就绪"——demo 和生产之间的差距，恰好是这个阶段要填的部分。',
  },
  {
    title: '阶段四 · 长期精进',
    goal: '从"会用工具"到"能设计系统"——这层没有终点，也不该有。',
    actions: [
      '系统设计判断力：分布式系统、并发模型、协议设计，不因某次模型升级而贬值。',
      '产品判断力：持续打磨"值不值得做、该做成什么样"的直觉，这是技术之外真正拉开差距的部分。',
      '领域纵深：选一个垂直方向扎进去，比"什么都会一点"更值钱。',
      '安全与治理：最小权限、致命三件套、审计与追责——治理预算的代价是非线性的，判断力越资深越值钱。',
      '持续跟踪但不追逐：协议和框架每年都会变，只需要知道地图在变哪里，不必每次从头学一遍。',
    ],
    deliverable: '没有单次交付物——这是复利，不是任务。',
    pitfall: '把长期精进也当成一份可以"做完"的清单，然后停下来。',
  },
];

interface ProjectIdea {
  title: string;
  desc: string;
  tags: string[];
}

const projects: ProjectIdea[] = [
  {
    title: 'RAG 知识助手 + 评估集',
    desc: '对自己的笔记 / 博客做语义检索问答，从向量检索基线开始，逐步加混合检索与 rerank，并配一套可回归的评估集。',
    tags: ['Python', 'RAG', '评估'],
  },
  {
    title: '自定义 MCP Server',
    desc: '把一个真实工具（自己的 API、内部服务）包装成 MCP Server，接入 Claude Desktop 或 Cursor，走完 schema 设计到鉴权的全流程。',
    tags: ['MCP', 'Client-Server'],
  },
  {
    title: 'LangGraph 有状态 Agent',
    desc: '一个真正会失败、会重试、可人工中断恢复的 Agent，而不是一次性跑通就收手的 demo。',
    tags: ['LangGraph', '状态机', '评估/可观测性'],
  },
  {
    title: 'Go 写的最小 LLM 网关',
    desc: '转发多个模型供应商的请求、做限流与 SSE 流式转发，是部署运维能力最直接的练习场。',
    tags: ['Go', '并发', '可用性'],
  },
  {
    title: '用户可配置的 Agent 产品原型',
    desc: '让非技术用户也能通过界面选择工具、调整编排逻辑、看到中间推理过程，而不是直接甩给用户一个聊天框。',
    tags: ['产品设计', '前端', 'Agent 体验'],
  },
  {
    title: 'AI 原生编码工作流护栏',
    desc: '给日常用 AI 写代码的流程加一道自动跑测试 / 检查的护栏，把阶段三讲的评估体系用在自己身上，而不只是用在 Agent 产品上。',
    tags: ['AI Coding', '自动化验证', '效率'],
  },
];

interface Reference {
  label: string;
  href: string;
}

const references: Reference[] = [
  { label: 'Anthropic · Building Effective Agents', href: 'https://www.anthropic.com/engineering/building-effective-agents' },
  { label: 'Anthropic · Effective context engineering for AI agents', href: 'https://www.anthropic.com/engineering/effective-context-engineering-for-ai-agents' },
  { label: 'Anthropic · Claude Code: Best practices for agentic coding', href: 'https://www.anthropic.com/engineering/claude-code-best-practices' },
  { label: 'Model Context Protocol · 官方规范', href: 'https://modelcontextprotocol.io' },
  { label: 'LangGraph · 官方文档', href: 'https://langchain-ai.github.io/langgraph/' },
  { label: 'OWASP · LLM06:2025 Excessive Agency', href: 'https://owasp.org/www-project-top-10-for-large-language-model-applications/2_0_vulns/LLM06_ExcessiveAgency.html' },
  { label: 'Simon Willison · The lethal trifecta for AI agents', href: 'https://simonwillison.net/2025/Jun/16/the-lethal-trifecta/' },
];

function durabilityClass(d: Durability | 'mixed'): string {
  if (d === 'mixed') return 'tag-mixed';
  return `tag-${d}`;
}

function durabilityLabel(d: Durability | 'mixed'): string {
  if (d === 'mixed') return '分层混合';
  return DURABILITY_LABEL[d];
}
---

<BaseLayout
  title="能力地图 · 前端 → AI Agent 工程师"
  description="从前端工程师到 AI Agent 全栈工程师的私人能力地图：按长期价值分层，覆盖技术栈与产品化能力两条轴。"
  noindex={true}
>
  <div class="breakout">
    <div class="shell">
      <header class="hero">
        <p class="eyebrow"><a href="/zen/">zen</a> · 能力地图 · 私人笔记</p>
        <h1>前端 <span class="arrow">→</span> AI Agent 工程师</h1>
        <p class="lead">
          这张地图不是任务清单，是一份用来对照的坐标系：把"前端转 AI Agent 工程师"这件事拆开，按"过多久还值钱"重新分层，而不是按"先学哪个后学哪个"排序。框架会换、协议会迭代，今天觉得重要的具体技能几年后大概也会改写，但底下那层"系统怎么设计、判断怎么下"，不会因为下一个模型发布而贬值。
        </p>
        <p class="meta-note">写于 2026-07-12，随认知更新，不追求一次写对。</p>
      </header>

      <section class="section">
        <h2>先看懂这张图怎么读</h2>
        <p class="section-intro">
          地图按<strong>半衰期</strong>分层，不按学习顺序排。越往下越不容易过时，也越难短期看出成果；越往上越容易上手出效果，但也最需要经常刷新。
        </p>
        <div class="legend">
          <span class="tag tag-durable">持久</span>
          <span class="tag tag-medium">中期</span>
          <span class="tag tag-volatile">易变</span>
          <span class="tag tag-mixed">分层混合</span>
        </div>

        <div class="stack">
          {[...layers].reverse().map((layer) => (
            <div class={`layer layer-${layer.durability}`} id={layer.id}>
              <div class="layer-head">
                <h3>{layer.name}</h3>
                <span class={`tag ${durabilityClass(layer.durability)}`}>{layer.halfLife}</span>
              </div>
              <ul class="chips">
                {layer.skills.map((skill) => (
                  <li>{skill}</li>
                ))}
              </ul>
              <p class="layer-note">{layer.note}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>AI 全栈产品开发能力</h2>
        <p class="section-intro">
          光有技术栈拆解还不够。AI 时代很容易长成"什么协议都懂，但做不出一个让人愿意用的产品"的样子。下面五项，是技术地图之外另一条同样值得长期投入的轴——产品判断力，而不只是执行细节。
        </p>
        <div class="cap-grid">
          {capabilities.map((cap, i) => (
            <article class="cap-card">
              <div class="cap-head">
                <span class="jd-index">{String(i + 1).padStart(2, '0')}</span>
                <span class={`tag ${durabilityClass(cap.durability)}`}>{durabilityLabel(cap.durability)}</span>
              </div>
              <h3 class="cap-title">{cap.title}</h3>
              <p class="cap-summary">{cap.summary}</p>
              <div class="jd-layers">
                {cap.layerTags.map((tag) => (
                  <span class="layer-tag">{tag}</span>
                ))}
              </div>
              <p class="jd-note">{cap.note}</p>
              {cap.link && (
                <a class="adv-link" href={cap.link.href}>延伸阅读：{cap.link.label}</a>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>你已经有的部分，不用重新学</h2>
        <p class="section-intro">
          前端工程师转 Agent 工程，常被低估的是迁移距离——很多"新能力"其实是旧直觉换了一个应用场景。
        </p>
        <div class="adv-grid">
          {advantages.map((adv) => (
            <article class="adv-card">
              <div class="adv-flow">
                <span class="adv-from">{adv.from}</span>
                <span class="adv-arrow">→</span>
                <span class="adv-to">{adv.to}</span>
              </div>
              <p class="adv-note">{adv.note}</p>
              {adv.link && (
                <a class="adv-link" href={adv.link.href}>延伸阅读：{adv.link.label}</a>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>分阶段怎么走</h2>
        <p class="section-intro">
          阶段不是严格的月份表，是"该先具备什么，才有资格谈下一件事"的依赖顺序。前三个阶段有明确产出，第四个阶段没有终点。
        </p>
        <div class="phases">
          {phases.map((phase, i) => (
            <article class="phase">
              <div class="phase-index">{i + 1}</div>
              <div class="phase-body">
                <h3>{phase.title}</h3>
                <p class="phase-goal">{phase.goal}</p>
                <ul class="phase-actions">
                  {phase.actions.map((action) => (
                    <li>{action}</li>
                  ))}
                </ul>
                <p class="phase-deliverable"><strong>关键产出：</strong>{phase.deliverable}</p>
                <p class="phase-pitfall"><strong>容易走偏：</strong>{phase.pitfall}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>用项目倒推，而不是收藏教程</h2>
        <p class="section-intro">
          课程建立词汇，项目才建立能力。六个方向覆盖技术栈与产品化能力两条轴，做完三四个基本就有了独立判断的底气。
        </p>
        <div class="project-grid">
          {projects.map((p) => (
            <article class="project-card">
              <h3>{p.title}</h3>
              <p>{p.desc}</p>
              <div class="project-tags">
                {p.tags.map((tag) => <span class="tag tag-neutral">{tag}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section closing">
        <h2>写在最后</h2>
        <p>
          好的地图不是用来一次走完的，是用来"知道自己现在站在哪一层"的。如果某段时间只顾着追新框架，那是在 L4 打转；如果很久没碰过评估、协议、系统设计，那是 L1、L2 在欠账；如果做出来的东西没人愿意用，大概是产品判断力欠账，而不是技术不够。
        </p>
        <p>
          <a href="/zen/">← 回到 zen</a>
        </p>
      </section>

      <footer class="refs">
        <p class="refs-title">参考资料</p>
        <ul>
          {references.map((ref) => (
            <li><a href={ref.href} target="_blank" rel="noopener noreferrer">{ref.label}</a></li>
          ))}
        </ul>
      </footer>
    </div>
  </div>
</BaseLayout>

