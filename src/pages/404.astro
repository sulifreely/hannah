---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到">
  <section class="notfound">
    <h1>404</h1>
    <p>这个页面不存在或已被移动。</p>
    <p><a href="/">← 返回首页</a></p>
  </section>
</BaseLayout>

<style>
  .notfound {
    text-align: center;
    padding: 4rem 0;
  }
  .notfound h1 {
    font-size: 4rem;
    margin: 0 0 1rem;
  }
  .notfound p {
    color: var(--fg-muted);
    margin: 0.5rem 0;
  }
  .notfound a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
