---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ScenesDeck from '../../../components/decks/ScenesDeck.astro';
import NotebookTabsDeck from '../../../components/decks/NotebookTabsDeck.astro';

export async function getStaticPaths() {
  const talks = await getCollection('talks', ({ data }) => !data.draft);
  return talks.map((talk) => ({
    params: { slug: talk.slug },
    props: { talk },
  }));
}

type Props = { talk: CollectionEntry<'talks'> };

const { talk } = Astro.props;
---

{talk.data.template === 'deck' ? <NotebookTabsDeck talk={talk} /> : <ScenesDeck talk={talk} />}
