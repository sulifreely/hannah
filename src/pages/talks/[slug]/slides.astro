---
/**
 * Public entry `/talks/<slug>/slides/` — redirect only.
 * Must NOT import either deck: a static import of both would merge CSS/JS
 * into this route's asset graph (see AGENT.md dual-import note).
 */
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const talks = await getCollection('talks', ({ data }) => !data.draft);
  return talks.map((talk) => ({
    params: { slug: talk.slug },
    props: { talk },
  }));
}

type Props = { talk: CollectionEntry<'talks'> };

const { talk } = Astro.props;
const suffix = talk.data.template === 'deck' ? 'slides-deck' : 'slides-scenes';
return Astro.redirect(`/talks/${talk.slug}/${suffix}/`, 308);
---
