---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TalkCard from '../../components/TalkCard.astro';

const talks = (await getCollection('talks', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Talks" description="蘇里的公开分享：演讲幻灯片与材料。">
  <section class="intro">
    <h1>Talks</h1>
    <p>公开分享的演讲幻灯片与材料。</p>
  </section>

  <section class="talks">
    {talks.length === 0 && <p class="empty">还没有公开的分享。</p>}
    {talks.map((talk) => (
      <TalkCard
        slug={talk.slug}
        title={talk.data.title}
        date={talk.data.date}
        description={talk.data.description}
        event={talk.data.event}
        tags={talk.data.tags}
        cover={talk.data.cover}
      />
    ))}
  </section>
</BaseLayout>

<style>
  .intro {
    margin-bottom: 1rem;
  }
  .intro h1 {
    margin: 0 0 0.5rem;
    font-size: 2rem;
  }
  .intro p {
    margin: 0;
    color: var(--fg-muted);
    font-size: 1.05rem;
  }
  .talks {
    margin-top: 2rem;
  }
  .empty {
    color: var(--fg-subtle);
  }
</style>
