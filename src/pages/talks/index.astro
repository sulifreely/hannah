---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const talks = (await getCollection('talks', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).format(d);
---

<BaseLayout title="Talks" description="蘇里的公开分享：演讲幻灯片与材料。">
  <section class="intro">
    <h1>Talks</h1>
    <p>公开分享的演讲幻灯片与材料。</p>
  </section>

  <section class="talks">
    {talks.length === 0 && <p class="empty">还没有公开的分享。</p>}
    {talks.map((talk) => (
      <article class="talk-card">
        <div class="card-body">
          <div class="meta">
            <time datetime={talk.data.date.toISOString()}>{fmt(talk.data.date)}</time>
            {talk.data.event && <span class="event">{talk.data.event}</span>}
            {talk.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
          </div>
          <h2 class="title">
            <a href={`/talks/${talk.slug}/`}>{talk.data.title}</a>
          </h2>
          <p class="desc">{talk.data.description}</p>
        </div>
        {talk.data.cover && (
          <a class="thumb" href={`/talks/${talk.slug}/`} aria-hidden="true" tabindex="-1">
            <img src={talk.data.cover} alt="" loading="lazy" />
          </a>
        )}
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .intro {
    margin-bottom: 1rem;
  }
  .intro h1 {
    margin: 0 0 0.5rem;
    font-size: 2rem;
  }
  .intro p {
    margin: 0;
    color: var(--fg-muted);
    font-size: 1.05rem;
  }
  .talks {
    margin-top: 2rem;
  }
  .talk-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .card-body {
    flex: 1;
    min-width: 0;
  }
  .thumb {
    flex-shrink: 0;
    display: block;
    width: 132px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .thumb img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  @media (max-width: 540px) {
    .thumb {
      width: 96px;
    }
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--fg-subtle);
    margin-bottom: 0.5rem;
  }
  .event {
    color: var(--fg-muted);
  }
  .tag {
    color: var(--fg-muted);
  }
  .title {
    margin: 0 0 0.4rem;
    font-size: 1.3rem;
  }
  .title a:hover {
    text-decoration: none;
    color: var(--accent-hover);
  }
  .desc {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.97rem;
    line-height: 1.65;
  }
  .empty {
    color: var(--fg-subtle);
  }
</style>
