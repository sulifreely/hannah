---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface ZenEntry {
  href: string;
  title: string;
  desc: string;
}

// 目录条目；路由本身由 astro.config.mjs 里 zenDevOnly() 在 dev 时 injectRoute。
const entries: ZenEntry[] = [
  {
    href: '/zen/ai-agent-engineer/',
    title: 'AI Agent 工程师',
    desc: '一份按长期价值分层、而非按学习顺序排列的技能地图。',
  },
];
---

<BaseLayout
  title="Zen"
  description="禅：正念当下，看清再动。"
  noindex={true}
>
  <article class="zen">
    <header class="hero">
      <h1>禅</h1>
    </header>

    <div class="prose">
      <p>正念当下。</p>
      <p>慢即是快。看清本质，再做判断。</p>
    </div>

    <section class="index">
      <p class="index-title">目录</p>
      <div class="entries">
        {entries.map((entry) => (
          <a class="entry" href={entry.href}>
            <span class="entry-title">{entry.title}</span>
            <span class="entry-desc">{entry.desc}</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .zen {
    max-width: 640px;
    margin: 0 auto;
  }
  .hero {
    margin-bottom: 2rem;
  }
  .hero h1 {
    margin: 0;
    font-size: 2.4rem;
  }
  .prose p {
    margin: 1rem 0;
    color: var(--fg-body);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .index {
    margin-top: 3rem;
  }
  .index-title {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }
  .entries {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .entry {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.1rem 1.3rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--paper);
    box-shadow: 3px 3px 0 var(--border);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .entry:hover {
    text-decoration: none;
    border-color: var(--accent);
    transform: translate(-1px, -1px);
  }
  .entry-title {
    color: var(--fg);
    font-weight: 700;
    font-size: 1.05rem;
  }
  .entry-desc {
    color: var(--fg-muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }
</style>
