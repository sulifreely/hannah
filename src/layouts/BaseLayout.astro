---
import 'lxgw-wenkai-webfont/style.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const siteName = '蘇里';
const defaultDesc = '蘇里的个人博客，记录工程、产品与个人成长的思考。';
const { title, description = defaultDesc, image = '/Y.png' } = Astro.props;
const pageTitle = title ? `${title} · ${siteName}` : `${siteName} · 个人博客`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/Y.png" />
    <link rel="apple-touch-icon" href="/Y.png" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header />
    <main class="wrap site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .site-main {
    padding-top: 2.5rem;
    min-height: 60vh;
  }
</style>
