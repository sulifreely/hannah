---
import '@fontsource/mulish/400.css';
import '@fontsource/mulish/600.css';
import '@fontsource/mulish/700.css';
import '@fontsource/mulish/800.css';
import '@fontsource/comic-neue/400.css';
import '@fontsource/comic-neue/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';
import 'lxgw-wenkai-lite-webfont/lxgwwenkailite-regular.css';
import 'lxgw-wenkai-lite-webfont/lxgwwenkailite-bold.css';
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const siteName = '蘇里';
const defaultDesc = '蘇里的个人博客，记录工程、产品与个人成长的思考。';
const { title, description = defaultDesc, image = '/favicon.png', noindex = false } = Astro.props;
const pageTitle = title ? `${title} · ${siteName}` : `${siteName} · 个人博客`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
    <Analytics />
  </head>
  <body>
    <Header />
    <main class="wrap site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  /* Sticky footer：只作用于 BaseLayout 自己渲染出的 html/body（Astro 会给
     这里的选择器加 scope 属性），不会像全局样式表那样泄漏进 talks 的
     slides 独立文档里。main 用 flex:1 吃掉除 header/footer 外的所有剩余
     高度，footer 因此始终贴底，无论内容多短；内容一多就自然把 footer 推下去。 */
  html {
    height: 100%;
  }

  body {
    min-height: 100%;
    display: flex;
    flex-direction: column;
  }

  .site-main {
    padding-top: 2.5rem;
    flex: 1;
  }
</style>
