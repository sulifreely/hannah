---
import BaseLayout from './BaseLayout.astro';
import LikeButton from '../components/LikeButton.astro';
import ViewCount from '../components/ViewCount.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  slug: string;
  title: string;
  date: Date;
  description: string;
  tags?: string[];
  cover?: string;
  headings?: Heading[];
}

const { slug, title, date, description, tags = [], cover, headings = [] } = Astro.props;

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const dateStr = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(date);
---

<BaseLayout title={title} description={description} image={cover}>
  {toc.length >= 2 && (
    <aside class="toc" aria-label="目录">
      <p class="toc-title">目录</p>
      <nav>
        <ul>
          {toc.map((h) => (
            <li class={`toc-item depth-${h.depth}`}>
              <a href={`#${h.slug}`} data-slug={h.slug}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )}
  <article class="post">
    <header class="post-header">
      <div class="meta">
        <time datetime={date.toISOString()}>{dateStr}</time>
        <ViewCount slug={slug} contentType="blog" mode="increment" />
        {tags.length > 0 && (
          <span class="tags">
            {tags.map((tag) => <span class="tag">#{tag}</span>)}
          </span>
        )}
      </div>
      <h1>{title}</h1>
    </header>
    {cover && <img class="cover" src={cover} alt={title} />}
    <div class="prose">
      <slot />
    </div>
    <footer class="post-footer">
      <a href="/">← 返回文章列表</a>
      <LikeButton slug={slug} title={title} contentType="blog" />
    </footer>
  </article>
  <button id="back-to-top" class="back-to-top" type="button" aria-label="返回顶部" title="返回顶部">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 19V5"></path>
      <path d="M5 12l7-7 7 7"></path>
    </svg>
  </button>
</BaseLayout>

<style>
  .toc {
    position: fixed;
    top: 7.5rem;
    right: calc(50% + 442px);
    width: 200px;
    max-height: calc(100vh - 11rem);
    overflow-y: auto;
    padding-left: 0.25rem;
    font-size: 0.85rem;
    line-height: 1.45;
  }
  .toc-title {
    margin: 0 0 0.6rem;
    padding-left: 0.85rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }
  .toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .toc-item.depth-3 a {
    padding-left: 1.7rem;
    font-size: 0.8rem;
  }
  .toc a {
    display: block;
    padding: 0.3rem 0.6rem 0.3rem 0.85rem;
    color: var(--fg-subtle);
    border-left: 2px solid var(--border);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .toc a:hover {
    color: var(--fg-muted);
    text-decoration: none;
  }
  .toc a.active {
    color: var(--accent);
    border-left-color: var(--accent);
  }
  @media (max-width: 1355px) {
    .toc {
      display: none;
    }
  }

  .post-header {
    margin-bottom: 2rem;
  }
  .cover {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-subtle);
    margin-bottom: 0.6rem;
  }
  .tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    color: var(--accent);
    background: var(--tag-bg);
    padding: 0.1em 0.55em;
    border-radius: 3px;
  }
  .post-header h1 {
    margin: 0;
    padding-bottom: 0.5rem;
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 3px;
    text-underline-offset: 0.3em;
    font-size: clamp(2rem, 1.3rem + 2.8vw, 2.6rem);
    font-weight: 750;
    line-height: 1.18;
    letter-spacing: -0.02em;
  }
  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.95rem;
    color: var(--fg-muted);
  }
  .post-footer a:hover {
    color: var(--fg);
  }
  @media (max-width: 480px) {
    .post-footer {
      flex-direction: column-reverse;
      align-items: flex-start;
    }
  }
  .back-to-top {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 50%;
    background: var(--paper);
    color: var(--fg-muted);
    box-shadow: 2px 2px 0 var(--border);
    cursor: pointer;
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    z-index: 40;
  }
  .back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .back-to-top:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  @media (max-width: 640px) {
    .back-to-top {
      right: 1rem;
      bottom: 1rem;
      width: 36px;
      height: 36px;
    }
  }
</style>

<style is:global>
  .prose {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--fg-body);
  }
  .prose > * + * {
    margin-top: 1.4rem;
  }
  .prose h2 {
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-size: 1.75rem;
    font-weight: 750;
    line-height: 1.3;
    scroll-margin-top: 1.5rem;
  }
  .prose h2::before {
    content: "· ";
    color: var(--accent);
  }
  .prose h3 {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.35;
    scroll-margin-top: 1.5rem;
  }
  .prose strong {
    color: var(--fg);
    font-weight: 700;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.4rem;
  }
  .prose li + li {
    margin-top: 0.4rem;
  }
  .prose a {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--fg-subtle);
  }
  .prose a:hover {
    text-decoration-color: var(--fg);
  }
  .prose blockquote {
    margin: 1.75rem 0;
    padding: 0.75rem 1.25rem;
    background: var(--tag-bg);
    border-left: 3px solid var(--accent);
    border-radius: 0 6px 6px 0;
    color: var(--fg);
    font-weight: 450;
  }
  .prose blockquote p {
    margin: 0;
  }
  .prose img {
    border-radius: 4px;
  }
  .prose img,
  .prose pre.mermaid[data-processed] svg {
    cursor: zoom-in;
  }
  .prose pre.mermaid {
    margin: 1.75rem 0;
    padding: 1.25rem 1rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--code-bg);
    text-align: center;
    line-height: normal;
    overflow-x: auto;
    /* 渲染完成前隐藏源码文本并预留高度，减少加载时的布局抖动 */
    color: transparent;
    font-size: 0;
    min-height: 200px;
  }
  .prose pre.mermaid[data-processed] {
    color: inherit;
    min-height: 0;
  }
  .prose pre.mermaid svg {
    max-width: 100%;
    height: auto;
  }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 1.75rem 0;
  }
  .prose th,
  .prose td {
    border: 1px solid var(--border);
    padding: 0.5rem 0.8rem;
    text-align: left;
    vertical-align: top;
  }
  .prose thead th {
    background: var(--tag-bg);
    font-weight: 650;
  }
  .prose tbody tr:nth-child(even) {
    background: color-mix(in srgb, var(--tag-bg) 45%, transparent);
  }
  .pswp {
    --pswp-bg: color-mix(in srgb, #000 86%, transparent);
    z-index: 1000;
  }
  .pswp__img {
    background: var(--code-bg);
  }
  .pswp__svg-content {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 12px;
    background: var(--code-bg);
  }
  .pswp__svg-content svg {
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    max-height: none !important;
    font-family: "Comic Neue", "LXGW WenKai Lite", cursive !important;
  }
  .pswp__svg-content text,
  .pswp__svg-content tspan,
  .pswp__svg-content foreignObject {
    font-family: inherit !important;
  }
</style>

<script is:inline>
  (function () {
    var links = Array.prototype.slice.call(
      document.querySelectorAll('.toc a[data-slug]')
    );
    if (!links.length) return;

    function setActive(slug) {
      links.forEach(function (l) {
        l.classList.toggle('active', l.getAttribute('data-slug') === slug);
      });
    }

    var headings = links
      .map(function (l) {
        return document.getElementById(l.getAttribute('data-slug'));
      })
      .filter(Boolean);

    // 用户点击目录后短暂锁定高亮，避免滚动监听把它改掉
    var manualSlug = null;
    var manualTimer = null;

    var visible = new Set();
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) visible.add(e.target.id);
          else visible.delete(e.target.id);
        });
        if (manualSlug) return;
        for (var i = 0; i < headings.length; i++) {
          if (visible.has(headings[i].id)) {
            setActive(headings[i].id);
            return;
          }
        }
      },
      { rootMargin: '-10% 0px -70% 0px', threshold: 0 }
    );

    headings.forEach(function (h) {
      observer.observe(h);
    });

    // 点击目录项：立即高亮 + 平滑滚动到对应标题
    links.forEach(function (l) {
      l.addEventListener('click', function (e) {
        var slug = l.getAttribute('data-slug');
        var target = document.getElementById(slug);
        if (!target) return;
        e.preventDefault();
        manualSlug = slug;
        setActive(slug);
        if (history.replaceState) {
          history.replaceState(null, '', '#' + slug);
        }
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        clearTimeout(manualTimer);
        manualTimer = setTimeout(function () {
          manualSlug = null;
        }, 900);
      });
    });

    // 带 #hash 直接进入时，让对应项高亮
    if (location.hash) {
      var initial = decodeURIComponent(location.hash.slice(1));
      if (initial) setActive(initial);
    }
  })();
</script>

<script is:inline>
  (function () {
    var btn = document.getElementById('back-to-top');
    if (!btn) return;

    function onScroll() {
      btn.classList.toggle('visible', window.scrollY > 480);
    }

    btn.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>

<script is:inline>
  // 目录是 fixed 定位，不随文档流滚出屏幕；文章较短时滚动到底部会与页脚重叠，
  // 这里根据目录与页脚的实时距离动态收缩目录高度，避免遮挡页脚内容。
  (function () {
    var toc = document.querySelector('.toc');
    var footer = document.querySelector('.site-footer');
    if (!toc || !footer) return;

    var GAP = 24;
    var ticking = false;

    function clampToc() {
      ticking = false;
      toc.style.maxHeight = '';
      var natural = parseFloat(getComputedStyle(toc).maxHeight) || toc.getBoundingClientRect().height;
      var tocTop = toc.getBoundingClientRect().top;
      var footerTop = footer.getBoundingClientRect().top;
      var available = footerTop - tocTop - GAP;
      var maxHeight = Math.max(0, Math.min(natural, available));
      toc.style.maxHeight = maxHeight + 'px';
    }

    function requestClamp() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(clampToc);
    }

    window.addEventListener('scroll', requestClamp, { passive: true });
    window.addEventListener('resize', requestClamp);
    clampToc();
  })();
</script>

<script>
  (function () {
    type ImagePreviewItem = {
      src: string;
      type: 'image';
      width: number;
      height: number;
      element: HTMLImageElement;
    };

    type SvgPreviewItem = {
      type: 'svg';
      width: number;
      height: number;
      element: SVGSVGElement;
    };

    type PreviewItem = ImagePreviewItem | SvgPreviewItem;

    let items: PreviewItem[] = [];

    function dimensionsFromSvg(svg: SVGSVGElement) {
      const viewBox = svg.viewBox.baseVal;
      if (viewBox && viewBox.width > 0 && viewBox.height > 0) {
        return { width: viewBox.width, height: viewBox.height };
      }
      const rect = svg.getBoundingClientRect();
      return {
        width: Math.max(1, Math.round(rect.width || 1200)),
        height: Math.max(1, Math.round(rect.height || 800)),
      };
    }

    function getPreviewItem(el: HTMLImageElement | SVGSVGElement): PreviewItem | null {
      if (el instanceof HTMLImageElement) {
        const src = el.currentSrc || el.src;
        if (!src) return null;
        return {
          src,
          type: 'image',
          width: Math.max(1, el.naturalWidth || el.clientWidth || 1200),
          height: Math.max(1, el.naturalHeight || el.clientHeight || 800),
          element: el,
        };
      }

      const { width, height } = dimensionsFromSvg(el);
      return {
        type: 'svg',
        width,
        height,
        element: el,
      };
    }

    async function openPreview(index: number) {
      const { default: PhotoSwipe } = await import('photoswipe');
      await import('photoswipe/style.css');

      const pswp = new PhotoSwipe({
        dataSource: items.map((item) => {
          if (item.type === 'svg') {
            return {
              type: 'svg',
              width: item.width,
              height: item.height,
              svgElement: item.element,
            };
          }
          return {
            src: item.src,
            width: item.width,
            height: item.height,
            element: item.element,
          };
        }) as import('photoswipe').SlideData[],
        index,
        showHideAnimationType: 'zoom',
        initialZoomLevel: 'fit',
        secondaryZoomLevel: 1.6,
        maxZoomLevel: 4,
        wheelToZoom: true,
        bgOpacity: 0.9,
      });
      pswp.on('contentLoad', (event) => {
        const { content } = event;
        if (content.data.type !== 'svg') return;

        event.preventDefault();

        const source = content.data.svgElement as SVGSVGElement | undefined;
        const wrapper = document.createElement('div');
        wrapper.className = 'pswp__svg-content';

        if (source) {
          const clone = source.cloneNode(true) as SVGSVGElement;
          clone.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
          clone.setAttribute('width', '100%');
          clone.setAttribute('height', '100%');
          clone.setAttribute('preserveAspectRatio', 'xMidYMid meet');
          // Mermaid 会给 SVG 设置内联 max-width，缩放结束后会把图钉回原尺寸，需要清除
          clone.style.maxWidth = 'none';
          clone.style.maxHeight = 'none';
          clone.style.width = '100%';
          clone.style.height = '100%';
          clone.style.fontFamily = '"Comic Neue", "LXGW WenKai Lite", cursive';
          wrapper.append(clone);
        }

        content.element = wrapper;
      });
      pswp.addFilter('isContentZoomable', (isZoomable, content) =>
        content.data.type === 'svg' ? true : isZoomable
      );
      pswp.init();
    }

    function bind(el: HTMLImageElement | SVGSVGElement) {
      if (el.dataset.previewBound === 'true') return;
      el.dataset.previewBound = 'true';
      el.tabIndex = 0;
      el.setAttribute('role', 'button');
      el.setAttribute('aria-label', '点击放大查看');
      el.addEventListener('click', (event) => {
        event.preventDefault();
        const index = items.findIndex((item) => item.element === el);
        if (index >= 0) openPreview(index);
      });
      el.addEventListener('keydown', (event) => {
        const keyboardEvent = event as KeyboardEvent;
        if (keyboardEvent.key === 'Enter' || keyboardEvent.key === ' ') {
          keyboardEvent.preventDefault();
          const index = items.findIndex((item) => item.element === el);
          if (index >= 0) openPreview(index);
        }
      });
    }

    function setupPostFigurePreview() {
      const figures = Array.from(
        document.querySelectorAll<HTMLImageElement | SVGSVGElement>('.prose img, .prose pre.mermaid svg')
      );
      items = figures
        .map(getPreviewItem)
        .filter((item): item is PreviewItem => Boolean(item));
      figures.forEach(bind);
    }

    window.addEventListener('DOMContentLoaded', setupPostFigurePreview);
    (window as typeof window & { setupPostFigurePreview?: () => void }).setupPostFigurePreview =
      setupPostFigurePreview;
  })();
</script>

<script>
  // 仅当文章里存在图表时才按需加载 mermaid，并跟随明暗主题重渲染
  (async function () {
    const blocks = Array.from(
      document.querySelectorAll<HTMLElement>('pre.mermaid')
    );
    if (!blocks.length) return;

    blocks.forEach((el, i) => {
      el.dataset.src = el.textContent || '';
      if (!el.id) el.id = 'mermaid-' + i;
    });

    const { default: mermaid } = await import('mermaid');
    const themeName = () =>
      document.documentElement.getAttribute('data-theme') === 'dark'
        ? 'dark'
        : 'neutral';

    async function render() {
      for (const el of blocks) {
        el.removeAttribute('data-processed');
        el.innerHTML = el.dataset.src || '';
      }
      mermaid.initialize({
        startOnLoad: false,
        look: 'handDrawn',
        handDrawnSeed: 1,
        theme: themeName(),
        securityLevel: 'strict',
        fontFamily: '"Comic Neue", "LXGW WenKai Lite", cursive',
      });
      for (const el of blocks) {
        try {
          await mermaid.run({ nodes: [el] });
        } catch (e) {
          el.dataset.processed = 'error';
          /* 单个图表语法错误时不阻断其他图表 */
        }
      }
      (
        window as typeof window & { setupPostFigurePreview?: () => void }
      ).setupPostFigurePreview?.();
    }

    await render();

    let last = themeName();
    new MutationObserver(() => {
      const t = themeName();
      if (t !== last) {
        last = t;
        render();
      }
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  })();
</script>
