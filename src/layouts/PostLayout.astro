---
import BaseLayout from './BaseLayout.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  date: Date;
  description: string;
  tags?: string[];
  cover?: string;
  headings?: Heading[];
}

const { title, date, description, tags = [], cover, headings = [] } = Astro.props;

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const dateStr = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(date);
---

<BaseLayout title={title} description={description} image={cover}>
  {toc.length >= 2 && (
    <aside class="toc" aria-label="目录">
      <p class="toc-title">目录</p>
      <nav>
        <ul>
          {toc.map((h) => (
            <li class={`toc-item depth-${h.depth}`}>
              <a href={`#${h.slug}`} data-slug={h.slug}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )}
  <article class="post">
    <header class="post-header">
      <div class="meta">
        <time datetime={date.toISOString()}>{dateStr}</time>
        {tags.length > 0 && (
          <span class="tags">
            {tags.map((tag) => <span class="tag">#{tag}</span>)}
          </span>
        )}
      </div>
      <h1>{title}</h1>
    </header>
    {cover && <img class="cover" src={cover} alt={title} />}
    <div class="prose">
      <slot />
    </div>
    <footer class="post-footer">
      <a href="/">← 返回文章列表</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .toc {
    position: fixed;
    top: 7.5rem;
    right: calc(50% + 384px);
    width: 200px;
    max-height: calc(100vh - 11rem);
    overflow-y: auto;
    padding-left: 0.25rem;
    font-size: 0.85rem;
    line-height: 1.45;
  }
  .toc-title {
    margin: 0 0 0.6rem;
    padding-left: 0.85rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }
  .toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .toc-item.depth-3 a {
    padding-left: 1.7rem;
    font-size: 0.8rem;
  }
  .toc a {
    display: block;
    padding: 0.3rem 0.6rem 0.3rem 0.85rem;
    color: var(--fg-subtle);
    border-left: 2px solid var(--border);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .toc a:hover {
    color: var(--fg-muted);
    text-decoration: none;
  }
  .toc a.active {
    color: var(--fg);
    border-left-color: var(--fg);
  }
  @media (max-width: 1239px) {
    .toc {
      display: none;
    }
  }

  .post-header {
    margin-bottom: 2rem;
  }
  .cover {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--fg-subtle);
    margin-bottom: 0.6rem;
  }
  .tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    color: var(--fg-muted);
  }
  .post-header h1 {
    margin: 0;
    font-size: clamp(2rem, 1.3rem + 2.8vw, 2.6rem);
    font-weight: 750;
    line-height: 1.18;
    letter-spacing: -0.02em;
  }
  .post-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.95rem;
    color: var(--fg-muted);
  }
  .post-footer a:hover {
    color: var(--fg);
  }
</style>

<style is:global>
  .prose {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--fg-body);
  }
  .prose > * + * {
    margin-top: 1.4rem;
  }
  .prose h2 {
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-size: 1.75rem;
    font-weight: 750;
    line-height: 1.3;
    scroll-margin-top: 1.5rem;
  }
  .prose h3 {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.35;
    scroll-margin-top: 1.5rem;
  }
  .prose strong {
    color: var(--fg);
    font-weight: 700;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.4rem;
  }
  .prose li + li {
    margin-top: 0.4rem;
  }
  .prose a {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--fg-subtle);
  }
  .prose a:hover {
    text-decoration-color: var(--fg);
  }
  .prose blockquote {
    margin: 1.75rem 0;
    padding: 0.5rem 0 0.5rem 1.3rem;
    border-left: 3px solid var(--fg-subtle);
    color: var(--fg);
    font-weight: 450;
  }
  .prose blockquote p {
    margin: 0;
  }
  .prose img {
    border-radius: 8px;
  }
  .prose pre.mermaid {
    margin: 1.75rem 0;
    padding: 1.25rem 1rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--code-bg);
    text-align: center;
    line-height: normal;
    overflow-x: auto;
    /* 渲染完成前隐藏源码文本并预留高度，减少加载时的布局抖动 */
    color: transparent;
    font-size: 0;
    min-height: 200px;
  }
  .prose pre.mermaid[data-processed] {
    color: inherit;
    min-height: 0;
  }
  .prose pre.mermaid svg {
    max-width: 100%;
    height: auto;
  }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 1.75rem 0;
  }
  .prose th,
  .prose td {
    border: 1px solid var(--border);
    padding: 0.5rem 0.8rem;
    text-align: left;
    vertical-align: top;
  }
  .prose thead th {
    background: var(--tag-bg);
    font-weight: 650;
  }
  .prose tbody tr:nth-child(even) {
    background: color-mix(in srgb, var(--tag-bg) 45%, transparent);
  }
</style>

<script is:inline>
  (function () {
    var links = Array.prototype.slice.call(
      document.querySelectorAll('.toc a[data-slug]')
    );
    if (!links.length) return;

    function setActive(slug) {
      links.forEach(function (l) {
        l.classList.toggle('active', l.getAttribute('data-slug') === slug);
      });
    }

    var headings = links
      .map(function (l) {
        return document.getElementById(l.getAttribute('data-slug'));
      })
      .filter(Boolean);

    // 用户点击目录后短暂锁定高亮，避免滚动监听把它改掉
    var manualSlug = null;
    var manualTimer = null;

    var visible = new Set();
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) visible.add(e.target.id);
          else visible.delete(e.target.id);
        });
        if (manualSlug) return;
        for (var i = 0; i < headings.length; i++) {
          if (visible.has(headings[i].id)) {
            setActive(headings[i].id);
            return;
          }
        }
      },
      { rootMargin: '-10% 0px -70% 0px', threshold: 0 }
    );

    headings.forEach(function (h) {
      observer.observe(h);
    });

    // 点击目录项：立即高亮 + 平滑滚动到对应标题
    links.forEach(function (l) {
      l.addEventListener('click', function (e) {
        var slug = l.getAttribute('data-slug');
        var target = document.getElementById(slug);
        if (!target) return;
        e.preventDefault();
        manualSlug = slug;
        setActive(slug);
        if (history.replaceState) {
          history.replaceState(null, '', '#' + slug);
        }
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        clearTimeout(manualTimer);
        manualTimer = setTimeout(function () {
          manualSlug = null;
        }, 900);
      });
    });

    // 带 #hash 直接进入时，让对应项高亮
    if (location.hash) {
      var initial = decodeURIComponent(location.hash.slice(1));
      if (initial) setActive(initial);
    }
  })();
</script>

<script>
  // 仅当文章里存在图表时才按需加载 mermaid，并跟随明暗主题重渲染
  (async function () {
    const blocks = Array.from(
      document.querySelectorAll<HTMLElement>('pre.mermaid')
    );
    if (!blocks.length) return;

    blocks.forEach((el, i) => {
      el.dataset.src = el.textContent || '';
      if (!el.id) el.id = 'mermaid-' + i;
    });

    const { default: mermaid } = await import('mermaid');
    const themeName = () =>
      document.documentElement.getAttribute('data-theme') === 'dark'
        ? 'dark'
        : 'neutral';

    async function render() {
      for (const el of blocks) {
        el.removeAttribute('data-processed');
        el.innerHTML = el.dataset.src || '';
      }
      mermaid.initialize({
        startOnLoad: false,
        look: 'handDrawn',
        handDrawnSeed: 1,
        theme: themeName(),
        securityLevel: 'loose',
        fontFamily: '"Comic Neue", "LXGW WenKai Lite", cursive',
      });
      try {
        await mermaid.run({ nodes: blocks });
      } catch (e) {
        /* 图表语法错误时不阻断页面 */
      }
    }

    await render();

    let last = themeName();
    new MutationObserver(() => {
      const t = themeName();
      if (t !== last) {
        last = t;
        render();
      }
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  })();
</script>
